@model List<MultiserviciosPiscinas.DTOs.HistorialServicioDto>
@{
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    /* Hacer que el <main> sea el contenedor del fondo */
    main {
        background: transparent !important;
        position: relative !important;
        overflow: hidden !important;
    }

    /* Imagen de fondo pegada al <main>, no a toda la ventana */
    main::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: url('/images/pool-bg.jpg');
        background-size: cover;
        background-position: center;
        filter: blur(2px) brightness(0.90) saturate(1.1);
        transform: scale(1.04);
        z-index: 0;
    }

    /* Overlay semitransparente */
    main::after {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(236, 254, 255, 0.80);
        z-index: 1;
    }

    .historial-wrap {
        font-family: 'DM Sans', sans-serif;
        position: relative;
        z-index: 2;
        padding-bottom: 40px;
    }

    .page-header {
        background: linear-gradient(135deg, rgba(13,148,136,0.93) 0%, rgba(8,145,178,0.89) 100%);
        border-radius: 18px;
        padding: 32px 36px;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255,255,255,0.2);
        box-shadow: 0 4px 24px rgba(13,148,136,0.2);
    }
    .page-header::before {
        content: '';
        position: absolute;
        top: -40px; right: -40px;
        width: 180px; height: 180px;
        background: rgba(255,255,255,0.08);
        border-radius: 50%;
    }
    .page-header h1 {
        font-family: 'DM Serif Display', serif;
        color: #fff; font-size: 2rem; margin: 0 0 6px;
        position: relative; z-index: 1;
        text-shadow: 0 2px 12px rgba(0,0,0,0.2);
    }
    .page-header p {
        color: rgba(255,255,255,0.9); margin: 0; font-size: 0.92rem;
        position: relative; z-index: 1;
    }

    .filter-card {
        background: rgba(255,255,255,0.88);
        backdrop-filter: blur(8px);
        border-radius: 16px;
        padding: 24px 28px;
        margin-bottom: 24px;
        box-shadow: 0 2px 20px rgba(13,148,136,0.1);
        border: 1px solid rgba(255,255,255,0.7);
    }
    .filter-card label {
        font-size: 0.78rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.06em; color: #0d9488; margin-bottom: 6px; display: block;
    }
    .filter-card .form-control {
        border: 1.5px solid #ccfbf1; border-radius: 10px;
        padding: 10px 14px; font-size: 0.9rem; color: #134e4a;
        background: rgba(255,255,255,0.9);
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .filter-card .form-control:focus {
        border-color: #0d9488; box-shadow: 0 0 0 3px rgba(13,148,136,0.12); outline: none;
    }

    .btn-teal {
        background: linear-gradient(135deg, #0d9488, #0891b2);
        color: #fff; border: none; border-radius: 10px;
        padding: 10px 24px; font-weight: 600; font-size: 0.88rem;
        transition: opacity 0.2s, transform 0.15s; cursor: pointer;
    }
    .btn-teal:hover { opacity: 0.92; transform: translateY(-1px); color: #fff; }

    .btn-outline-teal {
        background: rgba(255,255,255,0.8); color: #0d9488;
        border: 1.5px solid #0d9488; border-radius: 10px;
        padding: 10px 24px; font-weight: 600; font-size: 0.88rem;
        transition: all 0.2s; text-decoration: none; display: inline-block; text-align: center;
    }
    .btn-outline-teal:hover { background: #f0fdfa; color: #0d9488; }

    .service-card {
        background: rgba(255,255,255,0.88);
        backdrop-filter: blur(8px);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.7);
        box-shadow: 0 2px 16px rgba(13,148,136,0.08);
        margin-bottom: 14px;
        transition: box-shadow 0.2s, transform 0.2s;
        overflow: hidden;
    }
    .service-card:hover {
        box-shadow: 0 8px 32px rgba(13,148,136,0.18);
        transform: translateY(-2px);
        background: rgba(255,255,255,0.96);
    }
    .service-card-inner {
        display: flex; align-items: center;
        padding: 20px 24px; gap: 20px;
    }
    .service-num {
        width: 44px; height: 44px;
        background: linear-gradient(135deg, #ccfbf1, #a5f3fc);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; color: #0f766e; font-size: 1rem; flex-shrink: 0;
    }
    .service-info { flex: 1; min-width: 0; }
    .service-tipo { font-weight: 600; color: #134e4a; font-size: 0.98rem; margin-bottom: 2px; }
    .service-meta { font-size: 0.82rem; color: #6b7280; }
    .service-meta span { margin-right: 16px; }

    .badge-estado { padding: 5px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: 600; }
    .badge-cerrado   { background: #d1fae5; color: #065f46; }
    .badge-progreso  { background: #fef3c7; color: #92400e; }
    .badge-cancelado { background: #fee2e2; color: #991b1b; }
    .badge-abierto   { background: #dbeafe; color: #1e40af; }

    .btn-detalle {
        background: rgba(240,253,250,0.9); color: #0d9488;
        border: 1.5px solid #99f6e4; border-radius: 10px;
        padding: 8px 18px; font-size: 0.83rem; font-weight: 600;
        white-space: nowrap; text-decoration: none;
        transition: all 0.2s; flex-shrink: 0;
    }
    .btn-detalle:hover { background: #0d9488; color: #fff; border-color: #0d9488; }

    .empty-state { text-align: center; padding: 60px 20px; color: #6b7280; }
    .results-count { font-size: 0.82rem; color: #6b7280; margin-top: 8px; padding-left: 4px; }
</style>

<div class="historial-wrap">

    <div class="page-header">
        <h1><i class="bi bi-book"></i> Historial de Servicios</h1>
        <p>Revisá todos los servicios realizados en tus piscinas</p>
    </div>

    <div class="filter-card">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label>Fecha desde</label>
                <input type="date" name="fechaDesde" value="@ViewBag.FechaDesde" class="form-control" />
            </div>
            <div class="col-md-4">
                <label>Fecha hasta</label>
                <input type="date" name="fechaHasta" value="@ViewBag.FechaHasta" class="form-control" />
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn-teal w-100">Filtrar</button>
                <a asp-action="Index" class="btn-outline-teal w-100">Limpiar</a>
            </div>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div style="font-size:3rem; opacity:0.4; margin-bottom:12px;">📋</div>
            <p class="fw-semibold mb-1" style="color:#374151">Sin servicios encontrados</p>
            <p style="font-size:0.88rem">No hay servicios en el período seleccionado.</p>
        </div>
    }
    else
    {
        int index = 1;
        foreach (var item in Model)
        {
            string badgeClass = item.EstadoServicio == "Cerrado" ? "badge-cerrado"
                              : item.EstadoServicio == "En progreso" ? "badge-progreso"
                              : item.EstadoServicio == "Cancelado" ? "badge-cancelado"
                              : "badge-abierto";

            <div class="service-card">
                <div class="service-card-inner">
                    <div class="service-num">@index</div>
                    <div class="service-info">
                        <div class="service-tipo">@item.Tipo</div>
                        <div class="service-meta">
                            <span>📅 @item.FechaHora.ToString("dd/MM/yyyy HH:mm")</span>
                            <span>👤 @item.NombreTecnico</span>
                            @if (item.FechaCierre.HasValue)
                            {
                                <span>✅ Cerrado @item.FechaCierre.Value.ToString("dd/MM/yyyy")</span>
                            }
                        </div>
                    </div>
                    <span class="badge-estado @badgeClass">@item.EstadoServicio</span>
                    <a asp-action="Detalle" asp-route-id="@item.Id" class="btn-detalle">Ver detalle →</a>
                </div>
            </div>
            index++;
        }
        <p class="results-count">@Model.Count servicio(s) encontrado(s)</p>
    }

</div>

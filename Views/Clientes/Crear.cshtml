@model MultiserviciosPiscinas.Models.ClienteCreateViewModel

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Nuevo Cliente";
}

<input type="hidden" id="urlCantones" value="@Url.Action("GetCantones", "Perfiles")" />
<input type="hidden" id="urlDistritos" value="@Url.Action("GetDistritos", "Perfiles")" />

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="a-title mb-0">
        <i class="bi bi-person-plus-fill me-2"></i>Nuevo Cliente
    </h2>
    <a asp-action="Index" class="btn btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="card">
    <div class="card-body">

        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                <i class="bi bi-person-fill me-2"></i>Información personal
            </h5>
            <hr style="border-color: var(--color-accent);" />

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="Nombre" class="form-label fw-semibold"></label>
                    <input asp-for="Nombre" class="form-control" required />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="ApellidoPaterno" class="form-label fw-semibold"></label>
                    <input asp-for="ApellidoPaterno" class="form-control" required />
                    <span asp-validation-for="ApellidoPaterno" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="ApellidoMaterno" class="form-label fw-semibold"></label>
                    <input asp-for="ApellidoMaterno" class="form-control" required />
                    <span asp-validation-for="ApellidoMaterno" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Correo" class="form-label fw-semibold"></label>
                    <input asp-for="Correo" type="email" class="form-control" required />
                    <span asp-validation-for="Correo" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Telefono" class="form-label fw-semibold"></label>
                    <input asp-for="Telefono" class="form-control" placeholder="Ej: 8888-0000" required />
                    <span asp-validation-for="Telefono" class="text-danger small"></span>
                </div>
            </div>

            <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                <i class="bi bi-geo-alt-fill me-2"></i>Dirección
            </h5>
            <hr style="border-color: var(--color-accent);" />

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Provincia</label>
                    <select id="provinciaSelect" name="provinciaId" class="form-select" required>
                        <option value="">Seleccione una provincia...</option>
                        @foreach (var provincia in ViewBag.Provincias)
                        {
                            <option value="@provincia.Id">@provincia.Nombre</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Cantón</label>
                    <select id="cantonSelect" name="cantonId" class="form-select" disabled required>
                        <option value="">Seleccione un cantón...</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Distrito</label>
                    <select id="distritoSelect" asp-for="DistritoId" class="form-select" disabled required>
                        <option value="">Seleccione un distrito...</option>
                    </select>
                    <span asp-validation-for="DistritoId" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Direccion" class="form-label fw-semibold"></label>
                    <textarea asp-for="Direccion" class="form-control" rows="3"
                              placeholder="Otras señas exactas de la dirección..." required></textarea>
                    <span asp-validation-for="Direccion" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-2">
                <button type="submit" class="btn">
                    <i class="bi bi-check-circle-fill me-1"></i> Guardar Cliente
                </button>
                <a asp-action="Index" class="btn btn-sm" style="background-color: var(--color-text-muted) !important;">
                    Cancelar
                </a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <script src="~/js/ubicaciones.js"></script>
}

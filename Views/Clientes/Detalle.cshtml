@model MultiserviciosPiscinas.Models.Cliente

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Detalle Cliente";

    var nombreCompleto = $"{Model.Usuario.Nombre} {Model.Usuario.ApellidoPaterno} {Model.Usuario.ApellidoMaterno}".Trim();
    var telefono = Model.TelefonosCliente.FirstOrDefault()?.NumeroTelefono ?? "—";
    var direccion = Model.DireccionCliente.FirstOrDefault()?.Detalles ?? "—";
    var estadoTexto = Model.Usuario.Activo ? "Activo" : "Inactivo";
    var estadoClase = Model.Usuario.Activo ? "text-bg-success" : "text-bg-danger";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="a-title mb-0">
        <i class="bi bi-person-circle me-2"></i>Detalle del Cliente
    </h2>
    <a asp-action="Index" class="btn btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="row g-4">

    @* Tarjeta: Información Personal *@
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                    <i class="bi bi-person-fill me-2"></i>Información Personal
                </h5>
                <hr style="border-color: var(--color-accent);" />

                <div class="mb-3">
                    <div class="a-text-muted small mb-1">Nombre completo</div>
                    <div class="fw-semibold fs-5">@nombreCompleto</div>
                </div>

                <div class="mb-3">
                    <div class="a-text-muted small mb-1"><i class="bi bi-envelope me-1"></i>Correo electrónico</div>
                    <div>@Model.Usuario.Correo</div>
                </div>

                <div class="mb-3">
                    <div class="a-text-muted small mb-1"><i class="bi bi-telephone me-1"></i>Teléfono</div>
                    <div>@telefono</div>
                </div>

                <div class="mb-3">
                    <div class="a-text-muted small mb-1"><i class="bi bi-geo-alt me-1"></i>Dirección</div>
                    <div>@direccion</div>
                </div>

                <div>
                    <div class="a-text-muted small mb-1">Estado</div>
                    <span class="badge @estadoClase px-3 py-2">@estadoTexto</span>
                </div>
            </div>

            <div class="card-footer d-flex gap-2 justify-content-end bg-transparent border-0">
                <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-sm">
                    <i class="bi bi-pencil-fill me-1"></i> Editar
                </a>
                <a asp-action="Crear" asp-controller="Piscinas"
                   asp-route-clienteId="@Model.Id" class="btn btn-sm">
                    <i class="bi bi-water me-1"></i> Nueva Piscina
                </a>
            </div>
        </div>
    </div>

    @* Tarjeta: Piscinas Registradas *@
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                    <i class="bi bi-water me-2"></i>Piscinas Registradas
                    <span class="badge ms-2" style="background-color: var(--color-btn-bg);">
                        @Model.Piscina.Count()
                    </span>
                </h5>
                <hr style="border-color: var(--color-accent);" />

                @if (Model.Piscina.Any())
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var piscina in Model.Piscina)
                        {
                            <div class="d-flex align-items-center justify-content-between p-3 rounded"
                                 style="background: var(--color-body-bg); border: 1px solid #e1ecf4;">
                                <div>
                                    <div class="fw-semibold">Piscina #@piscina.Id</div>
                                    <div class="a-text-muted small">@piscina.Tipo</div>
                                </div>
                                <span class="badge"
                                      style="background-color: @(piscina.Estado == "Activo" ? "var(--color-success)" : "var(--color-text-muted)")">
                                    @piscina.Estado
                                </span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="bi bi-water fs-1 a-text-muted opacity-50"></i>
                        <p class="a-text-muted mt-2 mb-0">Sin piscinas registradas</p>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

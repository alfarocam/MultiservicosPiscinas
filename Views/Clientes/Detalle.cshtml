@model MultiserviciosPiscinas.Models.Cliente


@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Detalle Cliente";
}

<h2>Detalle Cliente</h2>

<div class="card">

    <div class="card-body">

        <p>
            <strong>Nombre:</strong>
            @Model.Usuario.Nombre
            @Model.Usuario.ApellidoPaterno
            @Model.Usuario.ApellidoMaterno
        </p>

        <p>
            <strong>Correo:</strong>
            @Model.Usuario.Correo
        </p>

        <p>
            <strong>Teléfono:</strong>
            @(Model.TelefonosCliente.FirstOrDefault()?.NumeroTelefono)
        </p>

        <p>
            <strong>Dirección:</strong>
            @(Model.DireccionCliente.FirstOrDefault()?.Detalles)
        </p>

        <p>
            <strong>Activo:</strong>
            @(Model.Usuario.Activo ? "Sí" : "No")
        </p>

    </div>

</div>

<hr />

<h4>Piscinas Registradas</h4>

@if (Model.Piscina.Any())
{
    <table class="table table-bordered">

        <thead>
            <tr>
                <th>ID</th>
                <th>Tipo</th>
                <th>Estado</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var piscina in Model.Piscina)
            {
                <tr>
                    <td>@piscina.Id</td>
                    <td>@piscina.Tipo</td>
                    <td>@piscina.Estado</td>
                </tr>
            }

        </tbody>

    </table>
}
else
{
    <p>No tiene piscinas registradas.</p>
}
@model IEnumerable<MultiserviciosPiscinas.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="a-title">Gestión de Clientes</h1>
        <a asp-action="Crear" asp-controller="Clientes" class="btn btn-primary">
            Nuevo Cliente
        </a>
    </div>

<div class="o-form-card">
    <div class="table-responsive">
        <table id="tablaClientes" class="table align-middle w-100" style="color: var(--color-text-dark);">
            <thead>
                <tr style="border-bottom: 2px solid #e1ecf4;">
                    <th class="a-text-muted small text-uppercase">ID</th>
                    <th class="a-text-muted small text-uppercase">Nombre</th>
                    <th class="a-text-muted small text-uppercase">Correo</th>
                    <th class="a-text-muted small text-uppercase">Teléfono</th>
                    <th class="a-text-muted small text-uppercase text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cliente in Model)
                {
                    <tr style="border-bottom: 1px solid #e1ecf4;">
                        <td>@cliente.Id</td>
                        <td>@cliente.Usuario.Nombre @cliente.Usuario.ApellidoPaterno</td>
                        <td>@cliente.Usuario.Correo</td>
                        <td>@(cliente.TelefonosCliente.FirstOrDefault()?.NumeroTelefono)</td>
                        <td class="text-center">
                            <a asp-action="Detalle"
                               asp-route-id="@cliente.Id"
                               class="btn btn-sm" title="Ver detalle"
                               style="background-color: transparent !important; color: var(--color-navbar-bg) !important; border: 1px solid var(--color-navbar-bg) !important; box-shadow: none !important;">
                                 Ver
                            </a>
                            <a asp-action="Editar"
                               asp-route-id="@cliente.Id"
                               class="btn btn-sm text-decoration-none" title="Editar cliente">
                                Editar
                            </a>
                            <a asp-action="Crear"
                               asp-controller="Piscinas"
                               asp-route-clienteId="@cliente.Id"
                               class="btn btn-sm" title="Crear piscina"
                               style="background-color: var(--color-footer-bg) !important;">
                                Crear Piscina
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/clientes-tabla.js"></script>
}

@model MultiserviciosPiscinas.Models.GastoOperativoViewModel

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Registrar gasto operativo";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Registrar gasto operativo</h2>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Crear" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="row g-3">

                <div class="col-md-6">
                    <label asp-for="CategoriaId" class="form-label">Categoría</label>
                    <select asp-for="CategoriaId" class="form-select">
                        <option value="">-- Seleccione una categoría --</option>
                        @foreach (var cat in ViewBag.Categorias as List<MultiserviciosPiscinas.Models.CategoriaGastoOperativo>)
                        {
                            <option value="@cat.Id">@cat.NombreCategoria</option>
                        }
                    </select>
                    <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Monto" class="form-label">Monto (₡)</label>
                    <input asp-for="Monto" type="number" step="0.01" min="0.01"
                           class="form-control" placeholder="0.00" />
                    <span asp-validation-for="Monto" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Fecha" class="form-label">Fecha</label>
                    <input asp-for="Fecha" type="date" class="form-control" />
                    <span asp-validation-for="Fecha" class="text-danger small"></span>
                </div>

                <div class="col-md-12">
                    <label asp-for="Descripcion" class="form-label">
                        Descripción <span class="text-muted">(opcional)</span>
                    </label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"
                              placeholder="Detalle del gasto..."></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                </div>

                <div class="col-md-12">
                    <label asp-for="Comprobante" class="form-label">
                        Comprobante <span class="text-muted">(opcional — JPG, PNG o PDF)</span>
                    </label>
                    <input asp-for="Comprobante" type="file"
                           accept=".jpg,.jpeg,.png,.pdf"
                           class="form-control" />
                    <span asp-validation-for="Comprobante" class="text-danger small"></span>
                </div>

            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Registrar gasto</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}

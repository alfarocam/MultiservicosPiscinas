@model List<MultiserviciosPiscinas.Models.GastoOperativo>
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Gastos Operativos";
}

<div class="c-page-header">
    <h2><i class="bi bi-cash-stack me-2"></i>Gastos Operativos</h2>
    <a asp-action="Crear" class="btn">+ Registrar gasto</a>
</div>

@if (TempData["MensajeExito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["MensajeExito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="c-data-card">
    <table class="c-data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Fecha</th>
                <th>Categoría</th>
                <th>Monto</th>
                <th>Descripción</th>
                <th>Registrado por</th>
                <th>Comprobante</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="text-center text-muted py-4">No hay gastos registrados.</td></tr>
            }
            else
            {
                int c = 1;
                foreach (var g in Model)
                {
                    <tr>
                        <td class="c-num">@c</td>
                        <td>@g.Fecha.ToString("dd/MM/yyyy")</td>
                        <td>@g.Categoria.NombreCategoria</td>
                        <td class="c-price">₡@g.Monto.ToString("N2")</td>
                        <td class="c-muted">@(g.Descripcion ?? "—")</td>
                        <td>@g.Usuario.Nombre @g.Usuario.ApellidoPaterno</td>
                        <td>
                            @if (!string.IsNullOrEmpty(g.ComprobanteRuta))
                            {
                                <a href="@g.ComprobanteRuta" target="_blank" class="c-btn-sm c-btn-sm-primary">
                                    <i class="bi bi-paperclip me-1"></i>Ver
                                </a>
                            }
                            else
                            {
                                <span class="c-muted">Sin comprobante</span>
                            }
                        </td>
                        <td>
                            @if (g.Estado == "Aprobado")
                            {
                                <span class="c-badge c-badge-green">Aprobado</span>
                            }
                            else if (g.Estado == "Pendiente")
                            {
                                <span class="c-badge c-badge-amber">Pendiente</span>
                            }
                            else
                            {
                                <span class="c-badge c-badge-red">Rechazado</span>
                            }
                        </td>
                    </tr>
                    c++;
                }
            }
        </tbody>
    </table>
</div>

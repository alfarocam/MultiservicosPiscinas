@model MultiserviciosPiscinas.DTOs.ReporteSatisfaccionDto
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>

    .reporte-wrap {
        font-family: 'DM Sans', sans-serif;
        position: relative;
        z-index: 2;
        padding-bottom: 40px;
    }

    .page-header {
        background: linear-gradient(135deg, rgba(13,148,136,0.93) 0%, rgba(8,145,178,0.89) 100%);
        border-radius: 18px;
        padding: 32px 36px;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255,255,255,0.2);
        box-shadow: 0 4px 24px rgba(13,148,136,0.2);
    }
    .page-header::before {
        content: '';
        position: absolute;
        top: -40px; right: -40px;
        width: 180px; height: 180px;
        background: rgba(255,255,255,0.08);
        border-radius: 50%;
    }
    .page-header h1 {
        font-family: 'DM Serif Display', serif;
        color: #fff; font-size: 2rem; margin: 0 0 6px;
        position: relative; z-index: 1;
        text-shadow: 0 2px 12px rgba(0,0,0,0.2);
    }
    .page-header p {
        color: rgba(255,255,255,0.9); margin: 0; font-size: 0.92rem;
        position: relative; z-index: 1;
    }

    .filter-card {
        background: rgba(255,255,255,0.88);
        backdrop-filter: blur(8px);
        border-radius: 16px;
        padding: 24px 28px;
        margin-bottom: 24px;
        box-shadow: 0 2px 20px rgba(13,148,136,0.1);
        border: 1px solid rgba(255,255,255,0.7);
    }
    .filter-card label {
        font-size: 0.78rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.06em; color: #0d9488; margin-bottom: 6px; display: block;
    }
    .filter-card .form-control {
        border: 1.5px solid #ccfbf1; border-radius: 10px;
        padding: 10px 14px; font-size: 0.9rem; color: #134e4a;
        background: rgba(255,255,255,0.9);
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .filter-card .form-control:focus {
        border-color: #0d9488; box-shadow: 0 0 0 3px rgba(13,148,136,0.12); outline: none;
    }

    .btn-teal {
        background: linear-gradient(135deg, #0d9488, #0891b2);
        color: #fff; border: none; border-radius: 10px;
        padding: 10px 24px; font-weight: 600; font-size: 0.88rem;
        transition: opacity 0.2s, transform 0.15s; cursor: pointer;
    }
    .btn-teal:hover { opacity: 0.92; transform: translateY(-1px); color: #fff; }

    .btn-outline-teal {
        background: rgba(255,255,255,0.8); color: #0d9488;
        border: 1.5px solid #0d9488; border-radius: 10px;
        padding: 10px 24px; font-weight: 600; font-size: 0.88rem;
        transition: all 0.2s; text-decoration: none; display: inline-block; text-align: center;
    }
    .btn-outline-teal:hover { background: #f0fdfa; color: #0d9488; }

    /* Tarjetas de resumen */
    .stat-card {
        background: rgba(255,255,255,0.88);
        backdrop-filter: blur(8px);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.7);
        box-shadow: 0 2px 16px rgba(13,148,136,0.08);
        padding: 28px 24px;
        text-align: center;
        transition: box-shadow 0.2s, transform 0.2s;
    }
    .stat-card:hover {
        box-shadow: 0 8px 32px rgba(13,148,136,0.16);
        transform: translateY(-2px);
    }
    .stat-val {
        font-family: 'DM Serif Display', serif;
        font-size: 2.4rem;
        font-weight: 700;
        line-height: 1;
        margin-bottom: 6px;
    }
    .stat-label {
        font-size: 0.82rem;
        color: #6b7280;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .stat-stars { margin-top: 8px; font-size: 1.1rem; }

    /* Tarjetas de tabla */
    .data-card {
        background: rgba(255,255,255,0.88);
        backdrop-filter: blur(8px);
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.7);
        box-shadow: 0 2px 16px rgba(13,148,136,0.08);
        margin-bottom: 24px;
        overflow: hidden;
    }
    .data-card-header {
        background: linear-gradient(135deg, rgba(13,148,136,0.93) 0%, rgba(8,145,178,0.89) 100%);
        padding: 16px 24px;
        font-family: 'DM Serif Display', serif;
        font-size: 1.05rem;
        color: #fff;
        display: flex; align-items: center; gap: 10px;
    }
    .data-card-body { padding: 0; }

    .data-table { width: 100%; border-collapse: collapse; }
    .data-table thead tr {
        background: rgba(240,253,250,0.9);
        border-bottom: 1px solid #e0f2f1;
    }
    .data-table thead th {
        padding: 12px 20px;
        font-size: 0.75rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.06em;
        color: #0d9488;
    }
    .data-table tbody tr {
        border-bottom: 1px solid rgba(224,242,241,0.6);
        transition: background 0.15s;
    }
    .data-table tbody tr:last-child { border-bottom: none; }
    .data-table tbody tr:hover { background: rgba(240,253,250,0.7); }
    .data-table tbody td {
        padding: 14px 20px;
        font-size: 0.9rem; color: #374151;
    }

    .badge-nivel { padding: 5px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: 600; }
    .nivel-excelente { background: #d1fae5; color: #065f46; }
    .nivel-bueno     { background: #dbeafe; color: #1e40af; }
    .nivel-regular   { background: #fef3c7; color: #92400e; }
    .nivel-critico   { background: #fee2e2; color: #991b1b; }

    .badge-calif { padding: 5px 12px; border-radius: 20px; font-size: 0.78rem; font-weight: 600; }
    .calif-5 { background: #d1fae5; color: #065f46; }
    .calif-4 { background: #dcfce7; color: #166534; }
    .calif-3 { background: #dbeafe; color: #1e40af; }
    .calif-2 { background: #fef3c7; color: #92400e; }
    .calif-1 { background: #fee2e2; color: #991b1b; }

    .empty-msg { padding: 24px; color: #9ca3af; font-size: 0.9rem; }
</style>

<div class="reporte-wrap">

    <!-- Header -->
    <div class="page-header">
        <h1><i class="bi bi-bar-chart-line"></i> Reporte de Satisfacción</h1>
        <p>Análisis de calificaciones y feedback de los clientes</p>
    </div>

    <!-- Filtro -->
    <div class="filter-card">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label>Fecha desde</label>
                <input type="date" name="fechaDesde"
                       value="@(Model.FechaDesde?.ToString("yyyy-MM-dd"))"
                       class="form-control" />
            </div>
            <div class="col-md-4">
                <label>Fecha hasta</label>
                <input type="date" name="fechaHasta"
                       value="@(Model.FechaHasta?.ToString("yyyy-MM-dd"))"
                       class="form-control" />
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn-teal w-100">Filtrar</button>
                <a asp-action="Index" class="btn-outline-teal w-100">Limpiar</a>
            </div>
        </form>
    </div>

    <!-- Tarjetas de resumen -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-val" style="color:#0d9488">
                    @Model.PromedioGeneral.ToString("F1") <span style="font-size:1.2rem; color:#9ca3af">/ 5</span>
                </div>
                <div class="stat-label">Promedio General</div>
                <div class="stat-stars">
                    @{
                        int estrellas = (int)Math.Round(Model.PromedioGeneral);
                        for (int i = 1; i <= 5; i++)
                        {
                            <span style="color: @(i <= estrellas ? "#f59e0b" : "#d1d5db")">★</span>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-val" style="color:#0891b2">@Model.TotalEncuestas</div>
                <div class="stat-label">Total de Encuestas</div>
                <div class="stat-stars" style="color:#0891b2; font-size:1.4rem;">
                    <i class="bi bi-clipboard-data"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-val" style="color:#ef4444">@Model.TotalCriticas</div>
                <div class="stat-label">Calificaciones Críticas (≤ 2)</div>
                <div class="stat-stars" style="color:#ef4444; font-size:1.4rem;">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Promedio por técnico -->
    <div class="data-card">
        <div class="data-card-header">
            <i class="bi bi-person-badge"></i> Promedio por Técnico
        </div>
        <div class="data-card-body">
            @if (!Model.PromediosPorTecnico.Any())
            {
                <p class="empty-msg">No hay datos para el período seleccionado.</p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Técnico</th>
                            <th>Promedio</th>
                            <th>Encuestas</th>
                            <th>Nivel</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.PromediosPorTecnico)
                        {
                            string nivelClass = t.Promedio >= 4.0 ? "nivel-excelente"
                                              : t.Promedio >= 3.0 ? "nivel-bueno"
                                              : t.Promedio >= 2.0 ? "nivel-regular"
                                              : "nivel-critico";
                            string nivelLabel = t.Promedio >= 4.0 ? "Excelente"
                                              : t.Promedio >= 3.0 ? "Bueno"
                                              : t.Promedio >= 2.0 ? "Regular"
                                              : "Crítico";
                            <tr>
                                <td class="fw-semibold">@t.NombreTecnico</td>
                                <td>
                                    <span style="font-weight:700; color:#0d9488">@t.Promedio.ToString("F2")</span>
                                    <span style="color:#9ca3af; font-size:0.82rem"> / 5</span>
                                </td>
                                <td>@t.TotalEncuestas</td>
                                <td><span class="badge-nivel @nivelClass">@nivelLabel</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- Últimas encuestas -->
    <div class="data-card">
        <div class="data-card-header">
            <i class="bi bi-chat-square-text"></i> Últimas 10 Encuestas
        </div>
        <div class="data-card-body">
            @if (!Model.UltimasEncuestas.Any())
            {
                <p class="empty-msg">No hay encuestas en el período seleccionado.</p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Servicio</th>
                            <th>Técnico</th>
                            <th>Calificación</th>
                            <th>Comentario</th>
                            <th>Fecha</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var enc in Model.UltimasEncuestas)
                        {
                            string califClass = enc.Calificacion == 5 ? "calif-5"
                                              : enc.Calificacion == 4 ? "calif-4"
                                              : enc.Calificacion == 3 ? "calif-3"
                                              : enc.Calificacion == 2 ? "calif-2"
                                              : "calif-1";
                            <tr>
                                <td style="color:#9ca3af">@enc.Id</td>
                                <td><span style="font-weight:600">#@enc.ServicioId</span> — @enc.TipoServicio</td>
                                <td>@enc.NombreTecnico</td>
                                <td><span class="badge-calif @califClass">@enc.Calificacion ★</span></td>
                                <td style="color:#6b7280; font-size:0.85rem">@(enc.Comentario ?? "—")</td>
                                <td style="color:#6b7280">@enc.FechaEnvio.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

</div>

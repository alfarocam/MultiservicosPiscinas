@model MultiserviciosPiscinas.DTOs.ReporteSatisfaccionDto
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="c-page-header">
    <h2><i class="bi bi-bar-chart-line me-2"></i>Reporte de Satisfacción</h2>
</div>

<div class="c-data-card mb-3" style="padding:20px 24px">
    <form method="get" asp-action="Index" class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label fw-semibold small text-muted text-uppercase" style="letter-spacing:.05em">Fecha desde</label>
            <input type="date" name="fechaDesde" value="@(Model.FechaDesde?.ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label fw-semibold small text-muted text-uppercase" style="letter-spacing:.05em">Fecha hasta</label>
            <input type="date" name="fechaHasta" value="@(Model.FechaHasta?.ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn w-100">Filtrar</button>
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Limpiar</a>
        </div>
    </form>
</div>

<!-- Stat cards: número primero -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="c-stat-card">
            <div class="c-stat-num c-stat-num-teal">
                @Model.PromedioGeneral.ToString("F1")
                <span class="c-stat-sub">/ 5</span>
            </div>
            <div class="c-stat-label">Promedio General</div>
            <div class="c-stat-stars">
                @{ int est = (int)Math.Round(Model.PromedioGeneral);
                   for (int i = 1; i <= 5; i++) { <span style="color:@(i <= est ? "#f59e0b" : "#d1d5db")">★</span> } }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="c-stat-card">
            <div class="c-stat-num c-stat-num-blue">@Model.TotalEncuestas</div>
            <div class="c-stat-label">Total de Encuestas</div>
            <div class="c-stat-icon" style="color:#0891b2"><i class="bi bi-clipboard-data"></i></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="c-stat-card">
            <div class="c-stat-num c-stat-num-red">@Model.TotalCriticas</div>
            <div class="c-stat-label">Calificaciones Críticas (≤ 2)</div>
            <div class="c-stat-icon" style="color:#ef4444"><i class="bi bi-exclamation-triangle"></i></div>
        </div>
    </div>
</div>

<!-- Promedio por técnico -->
<div class="c-data-card mb-3">
    <div style="background-color:var(--color-navbar-bg);padding:14px 20px;display:flex;align-items:center;gap:8px">
        <i class="bi bi-person-badge text-white"></i>
        <span class="fw-bold text-white" style="font-family:var(--font-family-heading)">Promedio por Técnico</span>
    </div>
    @if (!Model.PromediosPorTecnico.Any())
    {
        <p class="text-muted p-4">No hay datos para el período seleccionado.</p>
    }
    else
    {
        <table class="c-data-table">
            <thead><tr><th>Técnico</th><th>Promedio</th><th>Encuestas</th><th>Nivel</th></tr></thead>
            <tbody>
                @foreach (var t in Model.PromediosPorTecnico)
                {
                    string bc = t.Promedio >= 4.0 ? "c-badge-green" : t.Promedio >= 3.0 ? "c-badge-blue" : t.Promedio >= 2.0 ? "c-badge-amber" : "c-badge-red";
                    string bl = t.Promedio >= 4.0 ? "Excelente" : t.Promedio >= 3.0 ? "Bueno" : t.Promedio >= 2.0 ? "Regular" : "Crítico";
                    <tr>
                        <td class="fw-semibold">@t.NombreTecnico</td>
                        <td><span class="fw-bold" style="color:var(--color-btn-bg)">@t.Promedio.ToString("F2")</span> <span class="text-muted small">/ 5</span></td>
                        <td>@t.TotalEncuestas</td>
                        <td><span class="c-badge @bc">@bl</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Últimas encuestas -->
<div class="c-data-card">
    <div style="background-color:var(--color-navbar-bg);padding:14px 20px;display:flex;align-items:center;gap:8px">
        <i class="bi bi-chat-square-text text-white"></i>
        <span class="fw-bold text-white" style="font-family:var(--font-family-heading)">Últimas 10 Encuestas</span>
    </div>
    @if (!Model.UltimasEncuestas.Any())
    {
        <p class="text-muted p-4">No hay encuestas en el período seleccionado.</p>
    }
    else
    {
        <table class="c-data-table">
            <thead><tr><th>#</th><th>Servicio</th><th>Técnico</th><th>Calificación</th><th>Comentario</th><th>Fecha</th></tr></thead>
            <tbody>
                @foreach (var enc in Model.UltimasEncuestas)
                {
                    string cc = enc.Calificacion >= 4 ? "c-badge-green" : enc.Calificacion == 3 ? "c-badge-blue" : enc.Calificacion == 2 ? "c-badge-amber" : "c-badge-red";
                    <tr>
                        <td class="c-num">@enc.Id</td>
                        <td><span class="fw-semibold">#@enc.ServicioId</span> — @enc.TipoServicio</td>
                        <td>@enc.NombreTecnico</td>
                        <td><span class="c-badge @cc">@enc.Calificacion ★</span></td>
                        <td class="c-muted">@(enc.Comentario ?? "—")</td>
                        <td class="c-muted">@enc.FechaEnvio.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

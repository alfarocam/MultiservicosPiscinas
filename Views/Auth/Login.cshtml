@{
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
}

<div class="card shadow-sm border-0 rounded-3" style="width: 100%; max-width: 400px;">
    <div class="card-body p-5">
        <h4 class="card-title text-center mb-4 fw-bold">Iniciar Sesión</h4>
        <form asp-controller="Auth" asp-action="Login" method="post">
            <div class="mb-3">
                <label for="username" class="form-label fw-semibold">Usuario</label>
                <input type="text" class="form-control form-control-lg bg-light" id="username" name="username" placeholder="Ingresa tu usuario" required>
            </div>
            <div class="mb-3">
                <label for="password" class="form-label fw-semibold">Contraseña</label>
                <input type="password" class="form-control form-control-lg bg-light" id="password" name="password" placeholder="Ingresa tu contraseña" required>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 text-sm mt-3">
                <a href="@Url.Action("Register", "Auth")" class="text-decoration-none small">¿Crear cuenta?</a>
                <a href="@Url.Action("RecoverPassword", "Auth")" class="text-decoration-none small">¿Olvidaste tu contraseña?</a>
            </div>

            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-primary btn-lg shadow-sm">Ingresar al sistema</button>
            </div>
        </form>
    </div>
</div>


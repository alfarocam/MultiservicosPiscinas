@{
    Layout = null; // No layout for login page
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión — Multiservicios y Piscinas</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh;">

    <div class="card shadow-sm" style="width: 100%; max-width: 400px;">
        <div class="card-body p-4">
            <h4 class="card-title text-center mb-4">Iniciar Sesión</h4>
            <form asp-controller="Auth" asp-action="Login" method="post">
                <div class="mb-3">
                    <label for="username" class="form-label">Usuario</label>
                    <input type="text" class="form-control" id="username" name="username" placeholder="Usuario" required>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Contraseña</label>
                    <input type="password" class="form-control" id="password" name="password" placeholder="Contraseña">
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3 text-sm">
                    <a href="#" class="text-decoration-none small">¿Ya tienes una cuenta?</a>
                    <a href="#" class="text-decoration-none small">¿Olvidaste tu contraseña?</a>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Ingresar al sistema</button>
                </div>
            </form>
        </div>
    </div>

</body>
</html>

@model Usuario
@{
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
}

<div class="card o-form-card shadow-sm" style="width: 100%; max-width: 400px;">
    <div class="card-body p-4">
        <h4 class="a-title text-center mb-4">Iniciar Sesión</h4>

        @if (ViewBag.Mensaje != null)
        {
            <div class="alert alert-danger alert-dismissible fade show text-center small" role="alert">
                @ViewBag.Mensaje
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

        <form asp-controller="Auth" asp-action="InicioSesion" method="post">
            <div class="m-form-field">
                <label for="Correo" class="form-label fw-semibold">Correo</label>
                <input asp-for="Correo" name="Correo" type="email" class="form-control form-control-lg a-input" placeholder="Ingresa tu correo" required>
            </div>
            <div class="m-form-field">
                <label for="Contrasena" class="form-label fw-semibold">Contraseña</label>
                <input asp-for="Contrasena" name="Contrasena" type="password" class="form-control form-control-lg a-input" placeholder="Ingresa tu contraseña" required>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 text-sm mt-3">
                <a asp-action="Registrar" asp-controller="Auth" class="text-decoration-none small a-text-dark">¿Crear cuenta?</a>
                <a asp-action="RecuperarContrasena" asp-controller="Auth" class="text-decoration-none small a-text-dark">¿Olvidaste tu contraseña?</a>
            </div>

            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn a-btn btn-lg shadow-sm">Ingresar al sistema</button>
            </div>
        </form>
    </div>
</div>


@model Usuario
@{
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
    ViewData["Title"] = "Registro";
}

<div class="card o-form-card shadow-sm" style="width: 100%; max-width: 550px;">
    <div class="card-body p-4">
        <h4 class="a-title text-center mb-4">Crear Cuenta</h4>

        @if (ViewBag.Mensaje != null)
        {
            <div class="alert alert-danger alert-dismissible fade show text-center small" role="alert">
                @ViewBag.Mensaje
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

        <form asp-controller="Auth" asp-action="Registrar" method="post">
            <div class="m-form-field">
                <label for="Nombre" class="form-label fw-semibold">Nombre</label>
                <input asp-for="Nombre" name="Nombre" type="text" class="form-control form-control-lg a-input" placeholder="Ingresa tu nombre" required>
            </div>
            <div class="row">
                <div class="col-sm-6 m-form-field">
                    <label for="ApellidoPaterno" class="form-label fw-semibold">Apellido Paterno</label>
                    <input asp-for="ApellidoPaterno" name="ApellidoPaterno" type="text" class="form-control form-control-lg a-input" placeholder="Primer apellido" required>
                </div>
                <div class="col-sm-6 m-form-field">
                    <label for="ApellidoMaterno" class="form-label fw-semibold">Apellido Materno</label>
                    <input asp-for="ApellidoMaterno" name="ApellidoMaterno" type="text" class="form-control form-control-lg a-input" placeholder="Segundo apellido">
                </div>
            </div>
            <div class="m-form-field">
                <label for="Correo" class="form-label fw-semibold">Correo Electrónico</label>
                <input asp-for="Correo" name="Correo" type="email" class="form-control form-control-lg a-input" placeholder="correo@ejemplo.com" required>
            </div>
            <div class="m-form-field">
                <label for="Contrasena" class="form-label fw-semibold">Contraseña</label>
                <input asp-for="Contrasena" name="Contrasena" type="password" class="form-control form-control-lg a-input" placeholder="Crea una contraseña" required>
            </div>

            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn a-btn btn-lg shadow-sm">Crear Cuenta</button>
            </div>

            <div class="text-center mt-4">
                <a asp-action="InicioSesion" asp-controller="Auth" class="text-decoration-none small a-text-dark">¿Ya tienes una cuenta? Inicia sesión</a>
            </div>
        </form>
    </div>
</div>

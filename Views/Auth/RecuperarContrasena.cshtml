@model Usuario
@{
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
    ViewData["Title"] = "Recuperar Contraseña";
}

<div class="card o-form-card shadow-sm" style="width: 100%; max-width: 400px;">
    <div class="card-body p-4">
        <h4 class="a-title text-center mb-4">Recuperar Contraseña</h4>
        <p class="text-center text-muted small mb-4">Ingresa tu correo electrónico y te enviaremos las instrucciones para restablecer tu contraseña.</p>
        @if (ViewBag.Mensaje != null)
        {
            <div class="alert alert-danger alert-dismissible fade show text-center small" role="alert">
                @ViewBag.Mensaje
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <form asp-controller="Auth" asp-action="RecuperarContrasena" method="post">
            <div class="m-form-field">
                <label for="Correo" class="form-label fw-semibold">Correo Electrónico</label>
                <input asp-for="Correo" name="Correo" type="email" class="form-control form-control-lg a-input" placeholder="nombre@ejemplo.com" required>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn a-btn btn-lg shadow-sm">Recuperar Contraseña</button>
            </div>

            <div class="text-center mt-4">
                <a asp-action="InicioSesion" asp-controller="Auth" class="text-decoration-none small a-text-dark">Volver al inicio de sesión</a>
            </div>
        </form>
    </div>
</div>

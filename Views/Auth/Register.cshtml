@{
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
    ViewData["Title"] = "Registro";
}

<div class="card shadow-sm border-0 rounded-3" style="width: 100%; max-width: 550px;">
    <div class="card-body p-5">
        <h4 class="card-title text-center mb-4 fw-bold">Crear Cuenta</h4>

        @if (ViewBag.Mensaje != null)
        {
            <div class="alert alert-danger alert-dismissible fade show text-center small" role="alert">
                @ViewBag.Mensaje
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

        <form asp-controller="Auth" asp-action="Register" method="post">
            <div class="mb-3">
                <label for="Nombre" class="form-label fw-semibold">Nombre</label>
                <input type="text" class="form-control form-control-lg bg-light" id="Nombre" name="Nombre" placeholder="Ingresa tu nombre" required>
            </div>
            <div class="row">
                <div class="col-sm-6 mb-3">
                    <label for="ApellidoPaterno" class="form-label fw-semibold">Apellido Paterno</label>
                    <input type="text" class="form-control form-control-lg bg-light" id="ApellidoPaterno" name="ApellidoPaterno" placeholder="Primer apellido" required>
                </div>
                <div class="col-sm-6 mb-3">
                    <label for="ApellidoMaterno" class="form-label fw-semibold">Apellido Materno</label>
                    <input type="text" class="form-control form-control-lg bg-light" id="ApellidoMaterno" name="ApellidoMaterno" placeholder="Segundo apellido">
                </div>
            </div>
            <div class="mb-3">
                <label for="Correo" class="form-label fw-semibold">Correo Electrónico</label>
                <input type="email" class="form-control form-control-lg bg-light" id="Correo" name="Correo" placeholder="correo@ejemplo.com" required>
            </div>
            <div class="mb-3">
                <label for="Contrasena" class="form-label fw-semibold">Contraseña</label>
                <input type="password" class="form-control form-control-lg bg-light" id="Contrasena" name="Contrasena" placeholder="Crea una contraseña" required>
            </div>

            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-primary btn-lg shadow-sm">Crear Cuenta</button>
            </div>

            <div class="text-center mt-4">
                <a href="@Url.Action("Login", "Auth")" class="text-decoration-none small">¿Ya tienes una cuenta? Inicia sesión</a>
            </div>
        </form>
    </div>
</div>

@{
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
    ViewData["Title"] = "Recuperar Contraseña";
}

<div class="card shadow-sm border-0 rounded-3" style="width: 100%; max-width: 400px;">
    <div class="card-body p-5">
        <h4 class="card-title text-center mb-4 fw-bold">Recuperar Contraseña</h4>
        <p class="text-center text-muted small mb-4">Ingresa tu correo electrónico y te enviaremos las instrucciones para restablecer tu contraseña.</p>

        <form asp-controller="Auth" asp-action="RecoverPassword" method="post">
            <div class="mb-4">
                <label for="email" class="form-label fw-semibold">Correo Electrónico</label>
                <input type="email" class="form-control form-control-lg bg-light" id="email" name="email" placeholder="nombre@ejemplo.com" required>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg shadow-sm">Enviar Instrucciones</button>
            </div>

            <div class="text-center mt-4">
                <a href="@Url.Action("Login", "Auth")" class="text-decoration-none small">Volver al inicio de sesión</a>
            </div>
        </form>
    </div>
</div>

@model MultiserviciosPiscinas.Models.Usuario

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Nuevo Colaborador";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Registrar Técnico o Administrador (HU-1.4)</h2>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Nombre</label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej. Juan Carlos" required />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Apellido Paterno</label>
                    <input asp-for="ApellidoPaterno" class="form-control" placeholder="Ej. Duarte" required />
                    <span asp-validation-for="ApellidoPaterno" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-bold">Apellido Materno</label>
                    <input asp-for="ApellidoMaterno" class="form-control" placeholder="Ej. Mendoza" required />
                    <span asp-validation-for="ApellidoMaterno" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold">Correo Electrónico (Institucional)</label>
                    <input asp-for="Correo" type="email" class="form-control" placeholder="nombre@multiservicios.com" required />
                    <span asp-validation-for="Correo" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold">Rol de Personal Interno</label>
                    <select asp-for="RolId" class="form-select" asp-items="ViewBag.Roles" required>
                        <option value ="" disabled selected>-- Elija un Rol --</option>
                    </select>
                    <span asp-validation-for="RolId" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold">Contraseña Temporal</label>
                    <input asp-for="Contrasena" type="password" class="form-control" placeholder="Clave inicial" required />
                    <span asp-validation-for="Contrasena" class="text-danger small"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-person-plus-fill me-1"></i> Guardar Colaborador
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Roles y permisos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Roles y permisos</h2>
    <div>
        <a asp-action="Crear" class="btn btn-primary">+ Nuevo rol</a>
        <a asp-action="Asignar" class="btn btn-outline-primary ms-2">Asignar rol</a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Rol</th>
                    <th>Descripción</th>
                    <th>Usuarios asignados</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td>Administrador</td>
                    <td>Acceso total al sistema y configuración general.</td>
                    <td>1</td>
                    <td><span class="badge bg-success">Activo</span></td>
                </tr>
                <tr>
                    <td>2</td>
                    <td>Tecnico</td>
                    <td>Gestión de servicios, bitácoras y visitas técnicas.</td>
                    <td>1</td>
                    <td><span class="badge bg-success">Activo</span></td>
                </tr>
                <tr>
                    <td>3</td>
                    <td>Cliente</td>
                    <td>Acceso al portal de autogestión y consulta de información.</td>
                    <td>1</td>
                    <td><span class="badge bg-success">Activo</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Multiservicios y Piscinas</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar navbar-dark px-3 d-flex justify-content-between">
        <div class="d-flex align-items-center gap-2">
            <button id="sidebarToggle" class="btn btn-link text-white p-0 border-0 me-3" type="button" aria-label="Colapsar menú lateral">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-list" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5" />
                </svg>
            </button>
            <a class="navbar-brand a-logo fw-bold" href="@Url.Action("Index", "Dashboard")">Multiservicios y Piscinas</a>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="text-white small">@User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value</span>
            <form asp-controller="Auth" asp-action="CerrarSesion" method="post" onsubmit="localStorage.removeItem('activeSidebarLink')">
                <button type="submit" class="btn btn-outline-light btn-sm">Salir</button>
            </form>
        </div>
    </nav>


    <div class="t-app-container">
        <nav class="t-sidebar d-flex flex-column p-3 text-white">
            <ul class="nav nav-pills flex-column gap-1">

                <li>
                    <a asp-controller="Dashboard" asp-action="Index"
                       class="nav-link text-white ">
                        Dashboard
                    </a>
                </li>

                <li><hr class="border-secondary my-1" /></li>
                <li class="px-2 text-secondary" style="font-size:11px">OPERACIONES</li>

                <li>
                    <a asp-controller="Clientes" asp-action="Index"
                       class="nav-link text-white ">
                        Clientes
                    </a>
                </li>

                <li>
                    <a asp-controller="Piscinas" asp-action="Index"
                       class="nav-link text-white ">
                        Piscinas
                    </a>
                </li>

                <li>
                    <a asp-controller="ServiciosTecnicos" asp-action="Index"
                       class="nav-link text-white ">
                        Servicios Técnicos
                    </a>
                </li>

                <li>
                    <a asp-controller="Agenda" asp-action="Index"
                       class="nav-link text-white ">
                        Agenda
                    </a>
                </li>

                <li>
                    <a asp-controller="Inventario" asp-action="Index"
                       class="nav-link text-white ">
                        Inventario
                    </a>
                </li>

                <li>
                    <a asp-controller="Bitacora" asp-action="Index"
                       class="nav-link text-white ">
                        Bitácora
                    </a>
                </li>

                <li><hr class="border-secondary my-1" /></li>
                <li class="px-2 text-secondary" style="font-size:11px">FINANZAS</li>

                <li>
                    <a asp-controller="Cotizacion" asp-action="Crear"
                       class="nav-link text-white ">
                        Cotizaciones
                    </a>
                </li>

                <li>
                    <a asp-controller="Facturacion" asp-action="Index"
                       class="nav-link text-white ">
                        Facturación
                    </a>
                </li>

                <li>
                    <a asp-controller="Roles" asp-action="Index"
                       class="nav-link text-white ">
                        Roles y Permisos
                    </a>
                </li>

                <li>
                    <a asp-controller="Perfiles" asp-action="Detalle"
                       class="nav-link text-white ">
                        Perfiles
                    </a>
                </li>

                <!-- ✅ NUEVO — Camila HU-3.4 -->
                <li>
                    <a asp-controller="ReporteSatisfaccion" asp-action="Index"
                       class="nav-link text-white ">
                        Reporte Satisfacción
                    </a>
                </li>

            </ul>
        </nav>

        <main class="flex-grow-1 p-4" >
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Portal Cliente</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar navbar-dark px-3 d-flex justify-content-between">
        <div class="d-flex align-items-center gap-2">
            <button id="sidebarToggle" class="btn btn-link text-white p-0 border-0 me-3" type="button" aria-label="Colapsar menú lateral">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-list" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5" />
                </svg>
            </button>
            <a class="navbar-brand a-logo fw-bold" href="@Url.Action("Index", "Portal")">Multiservicios y Piscinas</a>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="text-white small">@User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value</span>
            <form asp-controller="Auth" asp-action="CerrarSesion" method="post" onsubmit="localStorage.removeItem('activeSidebarLink')">
                <button type="submit" class="btn btn-outline-light btn-sm">Salir</button>
            </form>
        </div>
    </nav>

    <div class="t-app-container">

        <nav class="t-sidebar d-flex flex-column p-3 text-white">
            <ul class="nav nav-pills flex-column gap-1">
                <li>
                    <a asp-controller="Portal" asp-action="Index"
                       class="nav-link text-white ">
                        Inicio
                    </a>
                </li>
                <li>
                    <a asp-controller="Piscinas" asp-action="MisPiscinas"
                       class="nav-link text-white ">
                        Mis Piscinas
                    </a>
                </li>
                <li>
                    <a asp-controller="Agenda" asp-action="MisCitas"
                       class="nav-link text-white ">
                        Mis Citas
                    </a>
                </li>
                <li>
                    <a asp-controller="Facturacion" asp-action="MisFacturas"
                       class="nav-link text-white ">
                        Mis Facturas
                    </a>
                </li>
                <!-- ✅ HU-2.5 Camila -->
                <li>
                    <a asp-controller="Historial" asp-action="Index"
                       class="nav-link text-white ">
                        Historial de Servicios
                    </a>
                </li>
                <li>
                    <a asp-controller="Perfiles" asp-action="Index"
                       class="nav-link text-white ">
                        Mi Perfil
                    </a>
                </li>
                <li>
                    <a asp-controller="Contacto" asp-action="Index"
                       class="nav-link text-white ">
                        Contacto y Soporte
                    </a>
                </li>
                <li>
                    <a asp-controller="Contacto" asp-action="Informacion"
                       class="nav-link text-white">
                        Medios de Contacto
                    </a>
                </li>
            </ul>
        </nav>

        <main class="flex-grow-1 p-4" >
            @RenderBody()
        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
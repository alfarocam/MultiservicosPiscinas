<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Multiservicios y Piscinas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="p-login-view">

    <nav class="navbar o-navbar navbar-dark px-3 d-flex justify-content-between">
        <a class="navbar-brand a-logo fw-bold" href="@Url.Action("InicioSesion", "Auth")">Multiservicios y Piscinas</a>
    </nav>

    <div class="flex-grow-1 d-flex align-items-center justify-content-center p-4">
        @RenderBody()
    </div>

    <footer class="footer o-footer py-3 text-center">
        <div class="container text-center">
            <span class="a-text-light">&copy; @DateTime.Now.Year — Multiservicios y Piscinas. Todos los derechos reservados.</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
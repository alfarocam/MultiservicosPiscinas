<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Panel Técnico</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar navbar-dark px-3 d-flex justify-content-between"
         style="background-color:#0d6efd">
        <a class="navbar-brand fw-bold" href="/Agenda">Panel Técnico</a>
        <div class="d-flex align-items-center gap-3">
            <span class="text-white small">@User.Identity!.Name</span>
            <form asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="/" method="post">
                <button type="submit" class="btn btn-outline-light btn-sm">Salir</button>
            </form>
        </div>
    </nav>

    <div class="d-flex" style="min-height:calc(100vh - 56px)">

        <nav class="d-flex flex-column p-3 text-white"
             style="width:220px; background-color:#0a58ca; min-height:100%">
            <ul class="nav nav-pills flex-column gap-1">
                <li>
                    <a asp-controller="Agenda" asp-action="Index"
                       class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Agenda" ? "active" : "")">
                        Mi Agenda
                    </a>
                </li>
                <li>
                    <a asp-controller="ServiciosTecnicos" asp-action="Index"
                       class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "ServiciosTecnicos" ? "active" : "")">
                        Servicios
                    </a>
                </li>
                <li>
                    <a asp-controller="Bitacora" asp-action="Index"
                       class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Bitacora" ? "active" : "")">
                        Bitácora
                    </a>
                </li>
                <li>
                    <a asp-controller="Inventario" asp-action="Index"
                       class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventario" ? "active" : "")">
                        Inventario
                    </a>
                </li>
                <li>
                    <a asp-controller="Perfiles" asp-action="Index"
                       class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Perfiles" ? "active" : "")">
                        Mi Perfil
                    </a>
                </li>
            </ul>
        </nav>

        <main class="flex-grow-1 p-4" style="background:#f8f9fa">
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
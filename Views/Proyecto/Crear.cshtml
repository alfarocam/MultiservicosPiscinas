@model MultiserviciosPiscinas.Models.ProyectoCreateViewModel

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Nuevo Proyecto";
}

<input type="hidden" id="urlPiscinasPorCliente" value="@Url.Action("GetPiscinasPorCliente", "Proyecto")" />

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="a-title mb-0">
        <i class="bi bi-hammer me-2"></i>Nuevo Proyecto
    </h2>
    <a asp-action="Index" class="btn btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="card">
    <div class="card-body">

        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <!-- Sección: Información de Cliente y piscina -->
            <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                <i class="bi bi-person-fill me-2"></i>Cliente y piscina
            </h5>
            <hr style="border-color: var(--color-accent);" />

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="ClienteId" class="form-label fw-semibold"></label>
                    <select asp-for="ClienteId" id="clienteSelect" class="form-select" required>
                        <option value="">Seleccione un cliente...</option>
                        @foreach (var c in ViewBag.Clientes)
                        {
                            <option value="@c.id">@c.nombre</option>
                        }
                    </select>
                    <span asp-validation-for="ClienteId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="PiscinaId" class="form-label fw-semibold"></label>
                    <select asp-for="PiscinaId" id="piscinaSelect" class="form-select" disabled>
                        <option value="">Sin piscina asociada (opcional)</option>
                        @foreach (var p in ViewBag.Piscinas)
                        {
                            <option value="@p.id">@p.texto</option>
                        }
                    </select>
                    <span asp-validation-for="PiscinaId" class="text-danger small"></span>
                </div>
            </div>

            <!-- Sección: Información del proyecto -->
            <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                <i class="bi bi-clipboard-fill me-2"></i>Información del proyecto
            </h5>
            <hr style="border-color: var(--color-accent);" />

            <div class="row g-3 mb-4">
                <div class="col-md-8">
                    <label asp-for="Nombre" class="form-label fw-semibold"></label>
                    <input asp-for="Nombre" class="form-control"
                           placeholder="Ej: Construcción piscina residencial Los Yoses" required />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Estado" class="form-label fw-semibold"></label>
                    <select asp-for="Estado" class="form-select" required>
                        <option value="">Seleccione un estado...</option>
                        @foreach (var estado in ViewBag.Estados)
                        {
                            <option value="@estado">@estado</option>
                        }
                    </select>
                    <span asp-validation-for="Estado" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"
                              placeholder="Descripción general del proyecto, alcance, materiales, etc."></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                </div>
            </div>

            <!-- Sección: Fechas y Presupuesto -->
            <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                <i class="bi bi-calendar-event-fill me-2"></i>Fechas y presupuesto
            </h5>
            <hr style="border-color: var(--color-accent);" />

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="FechaInicio" class="form-label fw-semibold"></label>
                    <input asp-for="FechaInicio" type="date" class="form-control" required />
                    <span asp-validation-for="FechaInicio" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="FechaFinEstimada" class="form-label fw-semibold"></label>
                    <input asp-for="FechaFinEstimada" type="date" class="form-control" />
                    <span asp-validation-for="FechaFinEstimada" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Presupuesto" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">₡</span>
                        <input asp-for="Presupuesto" type="number" step="0.01" min="0.01"
                               class="form-control" placeholder="0.00" required />
                    </div>
                    <span asp-validation-for="Presupuesto" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-2">
                <button type="submit" class="btn">
                    <i class="bi bi-check-circle-fill me-1"></i> Guardar Proyecto
                </button>
                <a asp-action="Index" class="btn btn-sm" style="background-color: var(--color-text-muted) !important;">
                    Cancelar
                </a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <script src="~/js/proyecto-crear.js"></script>
}

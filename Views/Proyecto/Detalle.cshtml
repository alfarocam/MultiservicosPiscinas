@model MultiserviciosPiscinas.Models.ProyectoConstruccion

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Detalle del Proyecto";

    var nombreCliente = $"{Model.Cliente.Usuario.Nombre} {Model.Cliente.Usuario.ApellidoPaterno} {Model.Cliente.Usuario.ApellidoMaterno}".Trim();
    var direccionPrincipal = Model.Cliente.DireccionCliente.FirstOrDefault(d => d.EsPrincipal == 1)
                          ?? Model.Cliente.DireccionCliente.FirstOrDefault();
    var distrito     = direccionPrincipal?.Distrito?.Nombre ?? "—";
    var canton       = direccionPrincipal?.Distrito?.Canton?.Nombre ?? "—";
    var provincia    = direccionPrincipal?.Distrito?.Canton?.Provincia?.Nombre ?? "—";
    var senasExactas = direccionPrincipal?.Detalles ?? "—";

    var colorEstado = Model.Estado switch
    {
        "En Planificación" => "var(--color-link)",
        "En ejecución"  => "var(--color-success)",
        "Pausado"       => "var(--color-accent-orange)",
        "Completado"    => "var(--color-btn-bg)",
        "Cancelado"     => "var(--color-text-muted)",
        _               => "var(--color-text-muted)"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="a-title mb-0">
        <i class="bi bi-hammer me-2"></i>Detalle del Proyecto
    </h2>
    <a asp-action="Index" asp-controller="Proyecto" class="btn btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="row g-4">

    <!-- Card izquierda: info del proyecto + descripción -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                    <i class="bi bi-clipboard-data me-2"></i>Información del proyecto
                </h5>
                <hr style="border-color: var(--color-accent);" />

                <div class="mb-3">
                    <div class="a-text-muted small mb-1">Nombre</div>
                    <div class="fw-bold fs-5">@Model.Nombre</div>
                </div>

                <div class="mb-3">
                    <div class="a-text-muted small mb-1">Estado</div>
                    <span class="badge px-3 py-2"
                          style="background-color: @colorEstado; font-size: 13px; border-radius: var(--border-radius-sm);">
                        @Model.Estado
                    </span>
                </div>

                <div class="mb-3">
                    <div class="a-text-muted small mb-1"><i class="bi bi-calendar-event me-1"></i>Fecha de inicio</div>
                    <div>@Model.FechaInicio.ToString("dd/MM/yyyy")</div>
                </div>

                <div class="mb-3">
                    <div class="a-text-muted small mb-1"><i class="bi bi-calendar-check me-1"></i>Fecha fin estimada</div>
                    <div>@(Model.FechaFinEstimada.HasValue ? Model.FechaFinEstimada.Value.ToString("dd/MM/yyyy") : "—")</div>
                </div>

                <div class="mb-3">
                    <div class="a-text-muted small mb-1"><i class="bi bi-cash-coin me-1"></i>Presupuesto</div>
                    <div class="fw-semibold">@Model.Presupuesto.ToString("C")</div>
                </div>

                @if (Model.Piscina != null)
                {
                    <div class="mb-3">
                        <div class="a-text-muted small mb-1"><i class="bi bi-water me-1"></i>Piscina asociada</div>
                        <div>@Model.Piscina.Tipo — @Model.Piscina.VolumenM3.ToString("F2") m³</div>
                    </div>
                }

                <h5 class="fw-bold mt-4 mb-3" style="color: var(--color-btn-bg);">
                    <i class="bi bi-file-text-fill me-2"></i>Descripción
                </h5>
                <hr style="border-color: var(--color-accent);" />
                <p class="mb-0" style="white-space: pre-line;">
                    @(string.IsNullOrWhiteSpace(Model.Descripcion) ? "Sin descripción." : Model.Descripcion)
                </p>
            </div>

            <div class="card-footer d-flex justify-content-end bg-transparent border-0">
                <a asp-action="Editar" asp-controller="Proyecto" asp-route-id="@Model.Id" class="btn btn-sm">
                    <i class="bi bi-pencil-fill me-1"></i> Editar
                </a>
            </div>
        </div>
    </div>

    <!-- Card derecha: cliente + ubicación -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                    <i class="bi bi-person-fill me-2"></i>Cliente
                </h5>
                <hr style="border-color: var(--color-accent);" />

                <div class="mb-2">
                    <div class="a-text-muted small mb-1">Nombre completo</div>
                    <div class="fw-semibold">@nombreCliente</div>
                </div>
                <div class="mb-4">
                    <div class="a-text-muted small mb-1">Correo</div>
                    <div>@Model.Cliente.Usuario.Correo</div>
                </div>

                <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                    <i class="bi bi-geo-alt-fill me-2"></i>Ubicación del cliente
                </h5>
                <hr style="border-color: var(--color-accent);" />

                <div class="mb-2">
                    <div class="a-text-muted small mb-1">Provincia</div>
                    <div class="fw-semibold">@provincia</div>
                </div>
                <div class="mb-2">
                    <div class="a-text-muted small mb-1">Cantón</div>
                    <div>@canton</div>
                </div>
                <div class="mb-2">
                    <div class="a-text-muted small mb-1">Distrito</div>
                    <div>@distrito</div>
                </div>
                <div>
                    <div class="a-text-muted small mb-1">Señas exactas</div>
                    <div class="p-2 rounded" style="background: var(--color-body-bg); border: 1px solid #e1ecf4;">
                        @senasExactas
                    </div>
                </div>
            </div>

            <div class="card-footer d-flex justify-content-end bg-transparent border-0">
                <a asp-action="Detalle" asp-controller="Clientes" asp-route-id="@Model.ClienteId" class="btn btn-sm">
                    <i class="bi bi-person-circle me-1"></i> Ver Cliente
                </a>
            </div>
        </div>
    </div>

</div>

@{
    ViewData["Title"] = "Portal del cliente";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Portal del cliente</h2>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5>Mis piscinas</h5>
                <h2 class="mb-0">2</h2>
                <p class="text-muted mb-0">Piscinas registradas</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5>Próximos servicios</h5>
                <h2 class="mb-0">1</h2>
                <p class="text-muted mb-0">Visitas programadas</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5>Facturas pendientes</h5>
                <h2 class="mb-0">1</h2>
                <p class="text-muted mb-0">Documentos por pagar</p>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-dark text-white">
        Resumen reciente
    </div>
    <div class="card-body">
        <p><strong>Último servicio:</strong> Mantenimiento preventivo realizado el 10/04/2026.</p>
        <p><strong>Próxima visita:</strong> 18/04/2026 a las 09:00 a.m.</p>
        <p class="mb-0"><strong>Recomendación:</strong> Revisar nivel de cloro en la próxima visita.</p>
    </div>
</div>
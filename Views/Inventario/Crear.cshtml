@model MultiserviciosPiscinas.Models.InventarioFormularioViewModel

@{
    Layout = User.IsInRole("2")
        ? "~/Views/Shared/_LayoutTecnico.cshtml"
        : "~/Views/Shared/_LayoutAdmin.cshtml";

    ViewData["Title"] = "Nuevo registro";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Nuevo registro</h2>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej. Cloro granulado" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CategoriaId" class="form-label"></label>
                    <select asp-for="CategoriaId" asp-items="Model.Categorias" class="form-select">
                        <option value="">Seleccione una categoría</option>
                    </select>
                    <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Stock" class="form-label"></label>
                    <input asp-for="Stock" type="number" class="form-control" placeholder="Ej. 25" />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Precio" class="form-label"></label>
                    <input asp-for="Precio" type="number" step="0.01" class="form-control" placeholder="Ej. 3500" />
                    <span asp-validation-for="Precio" class="text-danger small"></span>
                </div>

                <div class="col-md-12">
                    <label asp-for="Descripcion" class="form-label"></label>
                    <textarea asp-for="Descripcion"
                              class="form-control"
                              rows="3"
                              placeholder="Detalle del producto, presentación, uso recomendado o marca."></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
@model MultiserviciosPiscinas.Models.InventarioIndexViewModel

@{
    Layout = User.IsInRole("2")
        ? "~/Views/Shared/_LayoutTecnico.cshtml"
        : "~/Views/Shared/_LayoutAdmin.cshtml";

    ViewData["Title"] = "Inventario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Inventario</h2>
    <a asp-action="Crear" class="btn btn-primary">+ Nuevo producto</a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">
        @TempData["Exito"]
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Productos.Any())
        {
            <div class="p-4 text-center">
                <h5>No hay productos registrados</h5>
                <p class="text-muted mb-3">Todavía no se han registrado insumos o herramientas.</p>
                <a asp-action="Crear" class="btn btn-primary">Registrar primer producto</a>
            </div>
        }
        else
        {
            <table class="table table-bordered table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Producto</th>
                        <th>Categoría</th>
                        <th>Cantidad</th>
                        <th>Precio</th>
                        <th>Estado</th>
                        <th style="width: 120px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var producto in Model.Productos)
                    {
                        <tr>
                            <td>@producto.Id</td>
                            <td>
                                <strong>@producto.Nombre</strong>

                                @if (!string.IsNullOrWhiteSpace(producto.Descripcion))
                                {
                                    <div class="small text-muted">
                                        @producto.Descripcion
                                    </div>
                                }
                            </td>
                            <td>@producto.Categoria</td>
                            <td>@producto.Stock</td>
                            <td>₡@producto.Precio.ToString("N2")</td>
                            <td>
                                @if (!producto.Activo)
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                                else if (producto.Stock <= 0)
                                {
                                    <span class="badge bg-danger">Agotado</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Disponible</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Editar"
                                   asp-route-id="@producto.Id"
                                   class="btn btn-warning btn-sm">
                                    Editar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
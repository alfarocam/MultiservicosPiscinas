@model MultiserviciosPiscinas.Models.Producto
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Detalle del producto";
}

<div class="c-page-header">
    <h2><i class="bi bi-box-seam me-2"></i>@Model.Nombre</h2>
    @if (Model.Activo)
    {
        <span class="c-badge c-badge-green" style="font-size:0.85rem;padding:6px 16px">✓ Disponible</span>
    }
    else
    {
        <span class="c-badge c-badge-gray" style="font-size:0.85rem;padding:6px 16px">Inactivo</span>
    }
</div>

<div class="c-detail-card">
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="c-detail-field">
                <label>Categoría</label>
                <p>@Model.Categoria.NombreCategoria</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="c-detail-field c-field-blue">
                <label>Precio unitario</label>
                <p>₡@Model.Precio.ToString("N2")</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="c-detail-field c-field-amber">
                <label>Stock disponible</label>
                <p>@Model.Stock unidades</p>
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Descripcion))
        {
            <div class="col-12">
                <div class="c-detail-field c-field-gray">
                    <label>Descripción</label>
                    <p style="font-weight:400">@Model.Descripcion</p>
                </div>
            </div>
        }
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Editar" asp-route-id="@Model.Id" class="btn">
            <i class="bi bi-pencil me-1"></i>Editar producto
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver al listado
        </a>
    </div>
</div>

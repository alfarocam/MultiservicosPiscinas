@model MultiserviciosPiscinas.Models.Producto

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Editar producto";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Editar producto</h2>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Editar" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <input asp-for="Id" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">

                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label">Nombre del producto</label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CategoriaId" class="form-label">Categoría</label>
                    <select asp-for="CategoriaId" class="form-select">
                        <option value="">-- Seleccione una categoría --</option>
                        @foreach (var cat in ViewBag.Categorias as List<MultiserviciosPiscinas.Models.CategoriaProducto>)
                        {
                            <option value="@cat.Id"
                                    selected="@(cat.Id == (int)ViewBag.CategoriaSeleccionada ? "selected" : null)">
                                @cat.NombreCategoria
                            </option>
                        }
                    </select>
                    <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Precio" class="form-label">Precio (₡)</label>
                    <input asp-for="Precio" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="Precio" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Stock" class="form-label">Stock disponible</label>
                    <input asp-for="Stock" type="number" min="0" class="form-control" />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Estado</label>
                    <select asp-for="Activo" class="form-select">
                        <option value="true">Disponible</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="col-md-12">
                    <label asp-for="Descripcion" class="form-label">Descripción <span class="text-muted">(opcional)</span></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                </div>

            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Guardar cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}

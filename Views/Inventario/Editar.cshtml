@model MultiserviciosPiscinas.Models.InventarioFormularioViewModel

@{
    Layout = User.IsInRole("2")
        ? "~/Views/Shared/_LayoutTecnico.cshtml"
        : "~/Views/Shared/_LayoutAdmin.cshtml";

    ViewData["Title"] = "Editar inventario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Editar producto de inventario</h2>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Editar" method="post">
            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CategoriaId" class="form-label"></label>
                    <select asp-for="CategoriaId" asp-items="Model.Categorias" class="form-select">
                        <option value="">Seleccione una categoría</option>
                    </select>
                    <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Stock" class="form-label"></label>
                    <input asp-for="Stock" type="number" class="form-control" />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Precio" class="form-label"></label>
                    <input asp-for="Precio" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Precio" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Estado</label>
                    <select asp-for="Activo" class="form-select">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

                <div class="col-md-12">
                    <label asp-for="Descripcion" class="form-label"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-warning">Guardar cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
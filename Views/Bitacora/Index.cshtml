@model List<MultiserviciosPiscinas.Models.BitacoraAuditoria>
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Bitácora del sistema";

    string TraducirTabla(string tabla) => tabla switch
    {
        "inv.PRODUCTO"        => "Inventario — Producto",
        "fin.GASTO_OPERATIVO" => "Finanzas — Gasto operativo",
        _                     => tabla
    };
    string TraducirAccion(string accion) => accion switch
    {
        "INSERT" => "Registro nuevo",
        "UPDATE" => "Modificación",
        "DELETE" => "Eliminación",
        _        => accion
    };
}

<div class="c-page-header">
    <h2><i class="bi bi-journal-text me-2"></i>Bitácora del sistema</h2>
</div>

<div class="c-data-card">
    <table class="c-data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Fecha y hora</th>
                <th>Usuario</th>
                <th>Tipo de acción</th>
                <th>Módulo afectado</th>
                <th>Detalle</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center text-muted py-4">No hay actividades registradas en la bitácora.</td></tr>
            }
            else
            {
                int c = 1;
                foreach (var r in Model)
                {
                    <tr>
                        <td class="c-num">@c</td>
                        <td>@r.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="fw-semibold">@r.Usuario.Nombre @r.Usuario.ApellidoPaterno</td>
                        <td>
                            @if (r.Accion == "INSERT")
                            {
                                <span class="c-badge c-badge-green">@TraducirAccion(r.Accion)</span>
                            }
                            else if (r.Accion == "UPDATE")
                            {
                                <span class="c-badge c-badge-amber">@TraducirAccion(r.Accion)</span>
                            }
                            else
                            {
                                <span class="c-badge c-badge-red">@TraducirAccion(r.Accion)</span>
                            }
                        </td>
                        <td>@TraducirTabla(r.TablaAfectada)</td>
                        <td>
                            <a asp-action="Detalle" asp-route-id="@r.Id" class="c-btn-sm c-btn-sm-primary">
                                <i class="bi bi-eye me-1"></i>Ver detalle
                            </a>
                        </td>
                    </tr>
                    c++;
                }
            }
        </tbody>
    </table>
</div>

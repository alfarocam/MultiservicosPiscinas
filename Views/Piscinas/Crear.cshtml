@model MultiserviciosPiscinas.Models.Piscina

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Nueva piscina";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Nueva piscina</h2>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ClienteId" class="form-label"></label>
                    <select asp-for="ClienteId" asp-items="ViewBag.ClienteId" class="form-select">
                        <option value="">Seleccione un cliente</option>
                    </select>
                    <span asp-validation-for="ClienteId" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Tipo" class="form-label"></label>
                    <input asp-for="Tipo" class="form-control" placeholder="Residencial, Comercial..." />
                    <span asp-validation-for="Tipo" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Largo" class="form-label"></label>
                    <input asp-for="Largo" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Largo" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Ancho" class="form-label"></label>
                    <input asp-for="Ancho" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Ancho" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Profundidad" class="form-label"></label>
                    <input asp-for="Profundidad" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Profundidad" class="text-danger"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="Observaciones" class="form-label"></label>
                    <textarea asp-for="Observaciones" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Observaciones" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Guardar piscina</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
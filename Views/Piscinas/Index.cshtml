@model IEnumerable<MultiserviciosPiscinas.Models.Piscina>

@{
    ViewData["Title"] = "Piscinas";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="a-title">Gestión de Piscinas</h1>
        <a asp-action="Index" asp-controller="Clientes" class="btn a-btn-outline text-decoration-none"
           style="color: var(--color-navbar-bg) !important; border-color: var(--color-navbar-bg) !important;">
            Nueva Piscina
        </a>
    </div>

    <div class="o-form-card">
        <div class="table-responsive">
            <table id="tablaPiscinas" class="table align-middle w-100" style="color: var(--color-text-dark);">
                <thead>
                    <tr style="border-bottom: 2px solid #e1ecf4;">
                        <th class="a-text-muted small text-uppercase" hidden>ID</th>
                        <th class="a-text-muted small text-uppercase">Cliente</th>
                        <th class="a-text-muted small text-uppercase">Dirección</th>
                        <th class="a-text-muted small text-uppercase">Tipo</th>
                        <th class="a-text-muted small text-uppercase">Volumen (m³)</th>
                        <th class="a-text-muted small text-uppercase">Estado</th>
                        <th class="a-text-muted small text-uppercase text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var piscina in Model)
                    {
                        <tr style="border-bottom: 1px solid #e1ecf4;">
                            <td hidden>@piscina.Id</td>
                            <td>@piscina.Cliente.Usuario.Nombre @piscina.Cliente.Usuario.ApellidoPaterno</td>
                            <td>@piscina.Direccion.Detalles, @piscina.Direccion.Distrito.Nombre</td>
                            <td>@piscina.Tipo</td>
                            <td>@piscina.VolumenM3.ToString("0.##") m³</td>
                            <td>
                                @{
                                    var colorEstado = piscina.Estado switch
                                    {
                                        "Activa"           => "var(--color-success)",
                                        "En mantenimiento" => "var(--color-accent-orange)",
                                        "En construcción"  => "var(--color-link)",
                                        _                  => "var(--color-text-muted)"
                                    };
                                }
                                <span class="badge"
                                      style="background-color: @colorEstado; padding: 0.4rem 0.6rem; border-radius: var(--border-radius-sm);">
                                    @piscina.Estado
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Detalle" asp-controller="Piscinas" asp-route-id="@piscina.Id"
                                       class="btn btn-sm"
                                       style="background-color: transparent !important; color: var(--color-navbar-bg) !important; border: 1px solid var(--color-navbar-bg) !important; box-shadow: none !important;">
                                        Ver
                                    </a>
                                    <a asp-action="Editar" asp-controller="Piscinas" asp-route-id="@piscina.Id"
                                       class="btn btn-sm text-decoration-none">
                                        Editar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/piscinas.js" asp-append-version="true"></script>
}

@model IEnumerable<MultiservicosPiscinas.Models.Piscina>

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Piscinas";
    var contador = 1;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Piscinas</h2>
    <a asp-action="Crear" class="btn btn-primary">+ Nueva piscina</a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width:60px">#</th>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>Cliente</th>
                    <th>Dimensiones</th>
                    <th>Estado</th>
                    <th style="width:220px">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@contador</td>
                            <td>@item.Nombre</td>
                            <td>@item.Tipo</td>
                            <td>@(item.Cliente?.Nombre ?? "Sin cliente")</td>
                            <td>@item.Largo m x @item.Ancho m x @item.Profundidad m</td>
                            <td>
                                @if (item.Activa)
                                {
                                    <span class="badge bg-success">Activa</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactiva</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">Ver</a>
                                <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>

                                <form asp-action="Eliminar" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm"
                                            onclick="return confirm('¿Deseas eliminar esta piscina?')">
                                        Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                        contador++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            No hay piscinas registradas aún.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="a-title">Gestión de Piscinas</h1>
        <a asp-action="Crear" asp-controller="Piscinas" class="a-btn text-decoration-none">⚡ Nueva Piscina</a>
    </div>

    <div class="o-form-card">
        <div class="table-responsive">
            <table class="table align-middle" style="color: var(--color-text-dark); background: transparent;">
                <thead>
                    <tr style="border-bottom: 2px solid #e1ecf4;">
                        <th class="a-text-muted small text-uppercase">ID</th>
                        <th class="a-text-muted small text-uppercase">Cliente ID</th>
                        <th class="a-text-muted small text-uppercase">Dirección ID</th>
                        <th class="a-text-muted small text-uppercase">Tipo</th>
                        <th class="a-text-muted small text-uppercase">Volumen (m³)</th>
                        <th class="a-text-muted small text-uppercase">Estado</th>
                        <th class="a-text-muted small text-uppercase text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr style="border-bottom: 1px solid #e1ecf4;">
                        <td class="fw-bold">1</td>
                        <td>102</td>
                        <td>540</td>
                        <td>Fibra de Vidrio</td>
                        <td>45.50</td>
                        <td>
                            <span class="badge" style="background-color: var(--color-success); padding: 0.4rem 0.6rem; border-radius: var(--border-radius-sm);">Activa</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Detalle" asp-controller="Piscinas" class="btn btn-sm" style="background: transparent !important; color: var(--color-navbar-bg) !important; border: 1px solid var(--color-navbar-bg) !important; box-shadow: none;">Ver</a>
                            <a asp-action="Editar" asp-controller="Piscinas" class="a-btn btn-sm text-decoration-none">Editar</a>
                        </td>
                    </tr>
                    <tr style="border-bottom: 1px solid #e1ecf4;">
                        <td class="fw-bold">2</td>
                        <td>204</td>
                        <td>312</td>
                        <td>Concreto Premium</td>
                        <td>120.00</td>
                        <td>
                            <span class="badge" style="background-color: var(--color-accent-orange); padding: 0.4rem 0.6rem; border-radius: var(--border-radius-sm);">Mantenimiento</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Detalle" asp-controller="Piscinas" class="btn btn-sm" style="background: transparent !important; color: var(--color-navbar-bg) !important; border: 1px solid var(--color-navbar-bg) !important; box-shadow: none;">Ver</a>
                            <a asp-action="Editar" asp-controller="Piscinas" class="a-btn btn-sm text-decoration-none">Editar</a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
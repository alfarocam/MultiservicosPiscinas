@model MultiserviciosPiscinas.Models.Piscina

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Detalle de la piscina";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Detalle de la piscina</h2>
    <div>
        <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
        <a asp-action="Index" class="btn btn-secondary ms-2">Volver</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-dark text-white">
                Información de la piscina
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr>
                        <td class="text-muted" style="width:40%">Nombre</td>
                        <td><strong>@Model.Nombre</strong></td>
                    </tr>
                    <tr>
                        <td class="text-muted">Tipo</td>
                        <td>@Model.Tipo</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Cliente</td>
                        <td>@(Model.Cliente?.Nombre ?? "No asignado")</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Largo</td>
                        <td>@Model.Largo m</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Ancho</td>
                        <td>@Model.Ancho m</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Profundidad</td>
                        <td>@Model.Profundidad m</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Volumen estimado</td>
                        <td>@Model.VolumenM3.ToString("N2") m³</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Estado</td>
                        <td>
                            @if (Model.Activa)
                            {
                                <span class="badge bg-success">Activa</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactiva</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">Observaciones</td>
                        <td>@Model.Observaciones</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>
@model MultiserviciosPiscinas.Models.Piscina

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Detalle Piscina";

    var nombreCliente = $"{Model.Cliente.Usuario.Nombre} {Model.Cliente.Usuario.ApellidoPaterno}".Trim();
    var distrito = Model.Direccion?.Distrito?.Nombre ?? "—";
    var canton = Model.Direccion?.Distrito?.Canton?.Nombre ?? "—";
    var provincia = Model.Direccion?.Distrito?.Canton?.Provincia?.Nombre ?? "—";
    var detallesDireccion = Model.Direccion?.Detalles ?? "—";

    var colorEstado = Model.Estado switch
    {
        "Activa"              => "var(--color-success)",
        "Inactiva"            => "var(--color-text-muted)",
        "En mantenimiento"    => "var(--color-accent-orange)",
        "En construcción"     => "var(--color-link)",
        _                     => "var(--color-text-muted)"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="a-title mb-0">
        <i class="bi bi-water me-2"></i>Detalle de Piscina
    </h2>
    <a asp-action="Index" asp-controller="Piscinas" class="btn btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="row g-4">

    @* Tarjeta: Datos de la piscina *@
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                    <i class="bi bi-clipboard-data me-2"></i>Ficha Técnica
                </h5>
                <hr style="border-color: var(--color-accent);" />

                <div class="mb-3">
                    <div class="a-text-muted small mb-1">ID Piscina</div>
                    <div class="fw-bold fs-5">#@Model.Id</div>
                </div>

                <div class="mb-3">
                    <div class="a-text-muted small mb-1">
                        <i class="bi bi-person-fill me-1"></i>Cliente
                    </div>
                    <div class="fw-semibold">@nombreCliente</div>
                </div>

                <div class="mb-3">
                    <div class="a-text-muted small mb-1">
                        <i class="bi bi-tools me-1"></i>Tipo estructural
                    </div>
                    <div>@Model.Tipo</div>
                </div>

                <div class="mb-3">
                    <div class="a-text-muted small mb-1">
                        <i class="bi bi-droplet-half me-1"></i>Volumen
                    </div>
                    <div>@Model.VolumenM3.ToString("F2") m³</div>
                </div>

                <div>
                    <div class="a-text-muted small mb-1">Condición operativa</div>
                    <span class="badge px-3 py-2"
                          style="background-color: @colorEstado; font-size: 13px; border-radius: var(--border-radius-sm);">
                        @Model.Estado
                    </span>
                </div>
            </div>

            <div class="card-footer d-flex gap-2 justify-content-end bg-transparent border-0">
                <a asp-action="Historial" asp-controller="Piscinas"
                   asp-route-id="@Model.Id" class="btn btn-sm">
                    <i class="bi bi-clock-history me-1"></i> Historial
                </a>
                <a asp-action="Editar" asp-controller="Piscinas"
                   asp-route-id="@Model.Id" class="btn btn-sm">
                    <i class="bi bi-pencil-fill me-1"></i> Editar
                </a>
            </div>
        </div>
    </div>

    @* Tarjeta: Ubicación *@
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                    <i class="bi bi-geo-alt-fill me-2"></i>Ubicación
                </h5>
                <hr style="border-color: var(--color-accent);" />

                <div class="mb-3">
                    <div class="a-text-muted small mb-1">Provincia</div>
                    <div class="fw-semibold">@provincia</div>
                </div>

                <div class="mb-3">
                    <div class="a-text-muted small mb-1">Cantón</div>
                    <div>@canton</div>
                </div>

                <div class="mb-3">
                    <div class="a-text-muted small mb-1">Distrito</div>
                    <div>@distrito</div>
                </div>

                <div>
                    <div class="a-text-muted small mb-1">Señas exactas</div>
                    <div class="p-2 rounded" style="background: var(--color-body-bg); border: 1px solid #e1ecf4;">
                        @detallesDireccion
                    </div>
                </div>
            </div>

            <div class="card-footer d-flex justify-content-end bg-transparent border-0">
                <a asp-action="Detalle" asp-controller="Clientes"
                   asp-route-id="@Model.ClienteId" class="btn btn-sm">
                    <i class="bi bi-person-circle me-1"></i> Ver Cliente
                </a>
            </div>
        </div>
    </div>

</div>

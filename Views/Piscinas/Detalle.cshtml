<div class="container my-5" style="max-width: 600px;">
    <div class="mb-4">
        <h1 class="a-title">Ficha de Información</h1>
        <p class="a-text-muted">Detalles completos y parámetros técnicos asociados a la piscina.</p>
    </div>

    <div class="o-form-card">
        <div class="m-form-field mb-2">
            <span class="a-text-muted small text-uppercase">Identificador Único (ID)</span>
            <span class="a-text-dark fw-bold fs-5">1</span>
        </div>

        <hr style="border-top: 1px solid #e1ecf4; margin: 1.5rem 0;" />

        <div class="row">
            <div class="col-6 mb-3">
                <div class="m-form-field">
                    <span class="a-text-muted small text-uppercase">ID Cliente Asociado</span>
                    <strong class="a-text-dark">102</strong>
                </div>
            </div>
            <div class="col-6 mb-3">
                <div class="m-form-field">
                    <span class="a-text-muted small text-uppercase">ID Ubicación geográfica</span>
                    <strong class="a-text-dark">540</strong>
                </div>
            </div>
        </div>

        <div class="m-form-field mb-3">
            <span class="a-text-muted small text-uppercase">Tipo Estructural y Construcción</span>
            <strong class="a-text-dark">Fibra de Vidrio Premium</strong>
        </div>

        <div class="m-form-field mb-3">
            <span class="a-text-muted small text-uppercase">Caudal / Volumen Métrico</span>
            <strong class="a-text-dark">45.50 m³</strong>
        </div>

        <div class="m-form-field mb-4">
            <span class="a-text-muted small text-uppercase mb-1 d-block">Condición Operativa actual</span>
            <div>
                <span class="badge" style="background-color: var(--color-success); padding: 0.5rem 0.8rem; font-size: 13px; border-radius: var(--border-radius-sm);">Activa / Operacional</span>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4 pt-2" style="border-top: 1px solid #e1ecf4;">
            <a asp-action="Index" asp-controller="Piscinas" class="btn a-btn-outline d-flex align-items-center" style="color: var(--color-navbar-bg) !important; border-color: var(--color-navbar-bg) !important;">Volver a la Lista</a>
            <a asp-action="Editar" asp-controller="Piscinas" class="a-btn text-decoration-none">Editar Datos</a>
        </div>
    </div>
</div>
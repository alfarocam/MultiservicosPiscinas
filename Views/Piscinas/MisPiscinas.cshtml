@model List<MultiserviciosPiscinas.Models.PiscinaClienteListViewModel>

@{
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
    ViewData["Title"] = "Mis Piscinas";
}

<div class="container my-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="a-title mb-1">
                <i class="bi bi-water me-2"></i>Mis Piscinas
            </h1>
            <p class="a-text-muted mb-0">
                Consulta el estado actual de tus piscinas y sus próximas visitas programadas.
            </p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="o-form-card text-center py-5">
            <i class="bi bi-water" style="font-size: 3rem; color: var(--color-text-muted);"></i>

            <h4 class="mt-3 mb-2" style="color: var(--color-text-dark);">
                No tienes piscinas registradas
            </h4>

            <p class="a-text-muted mb-4">
                Actualmente no hay piscinas asociadas a tu cuenta.
                Puedes contactar al equipo de soporte para solicitar el registro de una piscina.
            </p>

            <a asp-controller="Contacto"
               asp-action="Index"
               class="a-btn text-decoration-none">
                Contactar soporte
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var piscina in Model)
            {
                var colorEstado = piscina.Estado switch
                {
                    "Activa" => "var(--color-success)",
                    "Inactiva" => "var(--color-text-muted)",
                    "En mantenimiento" => "var(--color-accent-orange)",
                    "En construcción" => "var(--color-link)",
                    _ => "var(--color-text-muted)"
                };

                <div class="col-md-6 col-xl-4">
                    <div class="card h-100 shadow-sm border-0">

                        <img src="@piscina.FotoUrl"
                             alt="Foto de piscina"
                             class="card-img-top"
                             style="height: 180px; object-fit: cover;"
                             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />

                        <div class="d-none align-items-center justify-content-center"
                             style="height: 180px; background: var(--color-body-bg); border-bottom: 1px solid #e1ecf4;">
                            <i class="bi bi-water" style="font-size: 3rem; color: var(--color-navbar-bg);"></i>
                        </div>

                        <div class="card-body">

                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="fw-bold mb-1" style="color: var(--color-text-dark);">
                                        Piscina #@piscina.PiscinaId
                                    </h5>
                                    <p class="a-text-muted small mb-0">
                                        @piscina.Tipo
                                    </p>
                                </div>

                                <span class="badge"
                                      style="background-color: @colorEstado; padding: 0.45rem 0.65rem; border-radius: var(--border-radius-sm);">
                                    @piscina.Estado
                                </span>
                            </div>

                            <div class="mb-3">
                                <div class="a-text-muted small mb-1">
                                    <i class="bi bi-droplet-half me-1"></i>Volumen
                                </div>
                                <div style="color: var(--color-text-dark);">
                                    @piscina.VolumenM3.ToString("0.##") m³
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="a-text-muted small mb-1">
                                    <i class="bi bi-geo-alt-fill me-1"></i>Dirección
                                </div>
                                <div class="small" style="color: var(--color-text-dark);">
                                    @piscina.Direccion
                                </div>
                            </div>

                            <hr style="border-color: #e1ecf4;" />

                            @if (piscina.ProximaVisitaFechaHora.HasValue)
                            {
                                <div class="p-3 rounded mb-3"
                                     style="background: var(--color-body-bg); border: 1px solid #e1ecf4;">
                                    <div class="a-text-muted small mb-1">
                                        <i class="bi bi-calendar-check me-1"></i>Próxima visita
                                    </div>

                                    <div class="fw-semibold" style="color: var(--color-text-dark);">
                                        @piscina.ProximaVisitaFechaHora.Value.ToString("dd/MM/yyyy HH:mm")
                                    </div>

                                    <div class="a-text-muted small">
                                        @piscina.ProximaVisitaTipo — @piscina.ProximaVisitaEstado
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="p-3 rounded mb-3"
                                     style="background: #fff8e6; border: 1px solid #ffe4a3;">
                                    <div class="small" style="color: var(--color-accent-orange);">
                                        <i class="bi bi-exclamation-circle me-1"></i>
                                        No hay próximas visitas programadas.
                                    </div>
                                </div>
                            }

                            <a asp-controller="Piscinas"
                               asp-action="DetalleMiPiscina"
                               asp-route-id="@piscina.PiscinaId"
                               class="btn btn-sm w-100"
                               style="background-color: transparent !important; color: var(--color-navbar-bg) !important; border: 1px solid var(--color-navbar-bg) !important; box-shadow: none !important;">
                                Ver detalle
                            </a>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

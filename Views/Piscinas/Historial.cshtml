@model MultiserviciosPiscinas.Models.Piscina

@{
    ViewData["Title"] = "Historial de Mantenimientos";
    var citas = Model.Cita.OrderByDescending(c => c.FechaHora).ToList();
}

<div class="container my-4" style="max-width: 860px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="a-title mb-1">Historial de Mantenimientos</h1>
            <p class="a-text-muted mb-0">
                Piscina #@Model.Id &mdash; @Model.Tipo &mdash;
                @Model.Cliente.Usuario.Nombre @Model.Cliente.Usuario.ApellidoPaterno
            </p>
        </div>
        <a asp-action="Index" asp-controller="Piscinas"
           class="btn a-btn-outline"
           style="color: var(--color-navbar-bg) !important; border-color: var(--color-navbar-bg) !important;">
            Volver
        </a>
    </div>

    @if (!citas.Any())
    {
        <div class="o-form-card text-center py-4">
            <p class="a-text-muted">No hay servicios registrados para esta piscina.</p>
        </div>
    }
    else
    {
        foreach (var cita in citas)
        {
            var colorTipo = cita.Tipo switch
            {
                "Mantenimiento" => "var(--color-btn-bg)",
                "Inspección"    => "var(--color-link)",
                "Reparación"    => "var(--color-accent-orange)",
                "Construcción"  => "var(--color-text-muted)",
                _               => "var(--color-text-muted)"
            };

            var colorEstado = cita.Estado switch
            {
                "Completada"  => "var(--color-success)",
                "En progreso" => "var(--color-accent-orange)",
                "En camino"   => "var(--color-link)",
                "Cancelada"   => "var(--color-danger)",
                _             => "var(--color-text-muted)"
            };
            <div class="o-form-card mb-4">

                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <span class="badge me-2"
                              style="background-color: @colorTipo; padding: 0.35rem 0.65rem; border-radius: var(--border-radius-sm); font-size: 0.8rem;">
                            @cita.Tipo
                        </span>
                        <span class="badge"
                              style="background-color: @colorEstado; padding: 0.35rem 0.65rem; border-radius: var(--border-radius-sm); font-size: 0.8rem;">
                            @cita.Estado
                        </span>
                        <p class="a-text-muted small mt-1 mb-0">
                            Técnico: <strong style="color: var(--color-text-dark);">
                                @cita.Tecnico.Nombre @cita.Tecnico.ApellidoPaterno
                            </strong>
                        </p>
                    </div>
                    <div class="text-end">
                        <p class="fw-bold mb-0" style="color: var(--color-text-dark);">
                            @cita.FechaHora.ToString("dd/MM/yyyy")
                        </p>
                        <p class="a-text-muted small mb-0">@cita.FechaHora.ToString("HH:mm")</p>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(cita.Notas))
                {
                    <p class="a-text-muted small mb-3" style="border-left: 3px solid var(--color-accent); padding-left: 0.75rem;">
                        @cita.Notas
                    </p>
                }

                @if (cita.Servicio != null)
                {
                    var servicio = cita.Servicio;

                    <hr style="border-color: #e1ecf4;" />

                    <p class="mb-2" style="color: var(--color-text-dark);">
                        <strong>Trabajo realizado:</strong> @servicio.TrabajoRealizado
                    </p>
                    <p class="a-text-muted small mb-3">
                        Apertura: @servicio.FechaApertura.ToString("dd/MM/yyyy")
                        @if (servicio.FechaCierre.HasValue)
                        {
                            <span>&mdash; Cierre: @servicio.FechaCierre.Value.ToString("dd/MM/yyyy")</span>
                        }
                        else
                        {
                            <span class="badge ms-2"
                                  style="background-color: var(--color-accent-orange); padding: 0.2rem 0.5rem; border-radius: var(--border-radius-sm); font-size: 0.75rem;">
                                Abierto
                            </span>
                        }
                    </p>

                    @if (servicio.TareaServicio.Any())
                    {
                        <p class="fw-bold small mb-2" style="color: var(--color-text-dark);">Tareas</p>
                        <div class="mb-3">
                            @foreach (var tarea in servicio.TareaServicio)
                            {
                                var iconTarea = tarea.Estado switch
                                {
                                    "Completada"  => "✓",
                                    "En progreso" => "◑",
                                    "Cancelada"   => "✕",
                                    _             => "○"
                                };
                                var colorTarea = tarea.Estado switch
                                {
                                    "Completada"  => "var(--color-success)",
                                    "En progreso" => "var(--color-accent-orange)",
                                    "Cancelada"   => "var(--color-danger)",
                                    _             => "var(--color-text-muted)"
                                };
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span style="color: @colorTarea; font-weight: 700; width: 1rem; text-align: center;">@iconTarea</span>
                                    <span class="small" style="color: var(--color-text-dark);">@tarea.Descripcion</span>
                                    <span class="a-text-muted small ms-auto">@tarea.Estado</span>
                                </div>
                            }
                        </div>
                    }

                    @if (servicio.Inspeccion.Any())
                    {
                        var inspeccion = servicio.Inspeccion.First();
                        <p class="fw-bold small mb-2" style="color: var(--color-text-dark);">
                            Mediciones Químicas &mdash; @inspeccion.FechaInspeccion.ToString("dd/MM/yyyy")
                        </p>
                        <div class="table-responsive mb-2">
                            <table class="table table-sm" style="font-size: 0.85rem; color: var(--color-text-dark);">
                                <thead>
                                    <tr style="border-bottom: 1px solid #e1ecf4;">
                                        <th class="a-text-muted" style="font-weight:600;">Cloro (ppm)</th>
                                        <th class="a-text-muted" style="font-weight:600;">Alcalinidad</th>
                                        <th class="a-text-muted" style="font-weight:600;">pH</th>
                                        <th class="a-text-muted" style="font-weight:600;">Calcio</th>
                                        <th class="a-text-muted" style="font-weight:600;">Ác. Cianúrico</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>@(inspeccion.CloroPpm?.ToString("0.##") ?? "—")</td>
                                        <td>@(inspeccion.Alcalinidad?.ToString("0.##") ?? "—")</td>
                                        <td>@(inspeccion.Ph?.ToString("0.##") ?? "—")</td>
                                        <td>@(inspeccion.Calcio?.ToString("0.##") ?? "—")</td>
                                        <td>@(inspeccion.AcidoCianurico?.ToString("0.##") ?? "—")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(inspeccion.Observaciones))
                        {
                            <p class="a-text-muted small mb-0"
                               style="border-left: 3px solid var(--color-btn-bg); padding-left: 0.75rem;">
                                @inspeccion.Observaciones
                            </p>
                        }
                    }
                }
            </div>
        }
    }
</div>

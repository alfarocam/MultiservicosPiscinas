@model MultiserviciosPiscinas.Models.PiscinaClienteDetalleViewModel

@{
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
    ViewData["Title"] = "Detalle de mi piscina";

    var colorEstado = Model.Estado switch
    {
        "Activa" => "var(--color-success)",
        "Inactiva" => "var(--color-text-muted)",
        "En mantenimiento" => "var(--color-accent-orange)",
        "En construcción" => "var(--color-link)",
        _ => "var(--color-text-muted)"
    };
}

<div class="container my-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="a-title mb-1">
                <i class="bi bi-water me-2"></i>Detalle de Piscina
            </h1>
            <p class="a-text-muted mb-0">
                Información técnica, equipamiento, parámetros y últimos servicios.
            </p>
        </div>

        <a asp-action="MisPiscinas"
           asp-controller="Piscinas"
           class="btn btn-sm"
           style="background-color: transparent !important; color: var(--color-navbar-bg) !important; border: 1px solid var(--color-navbar-bg) !important; box-shadow: none !important;">
            <i class="bi bi-arrow-left me-1"></i> Volver
        </a>
    </div>

    <div class="row g-4 mb-4">

        <div class="col-lg-5">
            <div class="card h-100 shadow-sm border-0">

                <img src="@Model.FotoUrl"
                     alt="Foto de piscina"
                     class="card-img-top"
                     style="height: 260px; object-fit: cover;"
                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />

                <div class="d-none align-items-center justify-content-center"
                     style="height: 260px; background: var(--color-body-bg); border-bottom: 1px solid #e1ecf4;">
                    <i class="bi bi-water" style="font-size: 4rem; color: var(--color-navbar-bg);"></i>
                </div>

                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h4 class="fw-bold mb-1" style="color: var(--color-text-dark);">
                                Piscina #@Model.PiscinaId
                            </h4>
                            <p class="a-text-muted mb-0">@Model.Tipo</p>
                        </div>

                        <span class="badge"
                              style="background-color: @colorEstado; padding: 0.5rem 0.7rem; border-radius: var(--border-radius-sm);">
                            @Model.Estado
                        </span>
                    </div>

                    <hr style="border-color: #e1ecf4;" />

                    <div class="mb-3">
                        <div class="a-text-muted small mb-1">
                            <i class="bi bi-droplet-half me-1"></i>Volumen
                        </div>
                        <div style="color: var(--color-text-dark);">
                            @Model.VolumenM3.ToString("0.##") m³
                        </div>
                    </div>

                    <div>
                        <div class="a-text-muted small mb-1">
                            <i class="bi bi-geo-alt-fill me-1"></i>Ubicación
                        </div>
                        <div class="small" style="color: var(--color-text-dark);">
                            @Model.DireccionCompleta
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="o-form-card h-100">
                <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                    <i class="bi bi-calendar-check me-2"></i>Próxima visita programada
                </h5>

                <hr style="border-color: var(--color-accent);" />

                @if (Model.ProximaVisitaFechaHora.HasValue)
                {
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="a-text-muted small mb-1">Fecha y hora</div>
                            <div class="fw-semibold" style="color: var(--color-text-dark);">
                                @Model.ProximaVisitaFechaHora.Value.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="a-text-muted small mb-1">Tipo de visita</div>
                            <div style="color: var(--color-text-dark);">
                                @Model.ProximaVisitaTipo
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="a-text-muted small mb-1">Estado de la cita</div>
                            <div style="color: var(--color-text-dark);">
                                @Model.ProximaVisitaEstado
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="a-text-muted small mb-1">Técnico asignado</div>
                            <div style="color: var(--color-text-dark);">
                                @(Model.ProximoTecnico ?? "No asignado")
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="bi bi-calendar-x" style="font-size: 2.5rem; color: var(--color-accent-orange);"></i>
                        <h5 class="mt-3 mb-2" style="color: var(--color-text-dark);">
                            Sin visitas próximas
                        </h5>
                        <p class="a-text-muted mb-0">
                            Actualmente no existe una visita programada para esta piscina.
                        </p>
                    </div>
                }
            </div>
        </div>

    </div>

    <div class="row g-4">

        <div class="col-lg-6">
            <div class="o-form-card h-100">
                <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                    <i class="bi bi-tools me-2"></i>Equipamiento
                </h5>

                <hr style="border-color: var(--color-accent);" />

                @if (Model.Equipamientos.Any())
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var equipo in Model.Equipamientos)
                        {
                            <span class="badge"
                                  style="background-color: var(--color-footer-bg); padding: 0.5rem 0.7rem; border-radius: var(--border-radius-sm);">
                                @equipo
                            </span>
                        }
                    </div>
                }
                else
                {
                    <p class="a-text-muted mb-0">
                        No hay equipamiento registrado para esta piscina.
                    </p>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="o-form-card h-100">
                <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
                    <i class="bi bi-clipboard-pulse me-2"></i>Últimos parámetros
                </h5>

                <hr style="border-color: var(--color-accent);" />

                @if (Model.UltimosParametros == null)
                {
                    <p class="a-text-muted mb-0">
                        No hay parámetros químicos registrados para esta piscina.
                    </p>
                }
                else
                {
                    <p class="a-text-muted small mb-3">
                        Fecha de inspección:
                        <strong style="color: var(--color-text-dark);">
                            @Model.UltimosParametros.FechaInspeccion.ToString("dd/MM/yyyy")
                        </strong>
                    </p>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle" style="color: var(--color-text-dark);">
                            <tbody>
                                <tr>
                                    <th class="a-text-muted">Cloro ppm</th>
                                    <td>@(Model.UltimosParametros.CloroPpm?.ToString("0.##") ?? "—")</td>
                                </tr>
                                <tr>
                                    <th class="a-text-muted">pH</th>
                                    <td>@(Model.UltimosParametros.Ph?.ToString("0.##") ?? "—")</td>
                                </tr>
                                <tr>
                                    <th class="a-text-muted">Alcalinidad</th>
                                    <td>@(Model.UltimosParametros.Alcalinidad?.ToString("0.##") ?? "—")</td>
                                </tr>
                                <tr>
                                    <th class="a-text-muted">Calcio</th>
                                    <td>@(Model.UltimosParametros.Calcio?.ToString("0.##") ?? "—")</td>
                                </tr>
                                <tr>
                                    <th class="a-text-muted">Ácido cianúrico</th>
                                    <td>@(Model.UltimosParametros.AcidoCianurico?.ToString("0.##") ?? "—")</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.UltimosParametros.Observaciones))
                    {
                        <p class="a-text-muted small mb-0"
                           style="border-left: 3px solid var(--color-btn-bg); padding-left: 0.75rem;">
                            @Model.UltimosParametros.Observaciones
                        </p>
                    }
                }
            </div>
        </div>

    </div>

    <div class="o-form-card mt-4">
        <h5 class="fw-bold mb-3" style="color: var(--color-btn-bg);">
            <i class="bi bi-clock-history me-2"></i>Últimos 3 servicios
        </h5>

        <hr style="border-color: var(--color-accent);" />

        @if (!Model.UltimosServicios.Any())
        {
            <p class="a-text-muted mb-0">
                No hay servicios registrados para esta piscina.
            </p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle w-100" style="color: var(--color-text-dark);">
                    <thead>
                        <tr style="border-bottom: 2px solid #e1ecf4;">
                            <th class="a-text-muted small text-uppercase">Fecha</th>
                            <th class="a-text-muted small text-uppercase">Tipo</th>
                            <th class="a-text-muted small text-uppercase">Estado</th>
                            <th class="a-text-muted small text-uppercase">Técnico</th>
                            <th class="a-text-muted small text-uppercase">Trabajo realizado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var servicio in Model.UltimosServicios)
                        {
                            var colorServicio = servicio.EstadoServicio switch
                            {
                                "Cerrado" => "var(--color-success)",
                                "En progreso" => "var(--color-accent-orange)",
                                "Cancelado" => "var(--color-danger)",
                                "Abierto" => "var(--color-link)",
                                _ => "var(--color-text-muted)"
                            };

                            <tr style="border-bottom: 1px solid #e1ecf4;">
                                <td>
                                    <strong>@servicio.FechaCita.ToString("dd/MM/yyyy")</strong>
                                    <div class="a-text-muted small">
                                        @servicio.FechaCita.ToString("HH:mm")
                                    </div>
                                </td>

                                <td>@servicio.TipoCita</td>

                                <td>
                                    <span class="badge"
                                          style="background-color: @colorServicio; padding: 0.4rem 0.6rem; border-radius: var(--border-radius-sm);">
                                        @servicio.EstadoServicio
                                    </span>
                                </td>

                                <td>@servicio.Tecnico</td>

                                <td class="small">
                                    @servicio.TrabajoRealizado
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>